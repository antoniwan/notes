---
import PageLayout from '../layouts/PageLayout.astro';
import LatestWatched from '../components/LatestWatched.astro';
import { fetchLetterboxdRecent } from '../utils/letterboxd';

const rssUrl = import.meta.env.LETTERBOXD_RSS_URL ?? '';
const profileUrl = import.meta.env.LETTERBOXD_PROFILE_URL ?? 'https://letterboxd.com/';

const letterboxdFilms = await fetchLetterboxdRecent(rssUrl, 12);

type AboutTopic = {
  label: string;
  hint: string;
  emoji: string;
  /** Matches `/category/[category]` when set (see `src/data/categories.ts`). */
  categoryId?: string;
};

const topics: AboutTopic[] = [
  {
    label: 'Integration & Growth',
    hint: 'From insight to embodiment, from performing to being',
    emoji: '\u{1F9D8}\u{1F3FD}\u{200D}\u{2642}\u{FE0F}',
    categoryId: 'integration-growth',
  },
  {
    label: 'Parenting',
    hint: 'Presence with my kids, the sacred in the ordinary',
    emoji: '\u{1F468}\u{200D}\u{1F469}\u{200D}\u{1F467}\u{200D}\u{1F466}',
    categoryId: 'parenting',
  },
  {
    label: 'Love & Revolution',
    hint: 'A home rooted in kindness; love as the final revolution',
    emoji: '\u{1F49C}',
  },
  {
    label: 'Clear Signals',
    hint: 'Honest environments, boundaries, real connection',
    emoji: '\u{1F4E1}',
    categoryId: 'psychology',
  },
  {
    label: 'Politics & Culture',
    hint: 'Systems that serve people; dignity that need not be earned',
    emoji: '\u{2696}\u{FE0F}',
    categoryId: 'politics',
  },
  {
    label: 'Psychology',
    hint: "Human behavior, healing, the body's wisdom",
    emoji: '\u{1F9E0}',
    categoryId: 'psychology',
  },
  {
    label: 'Art & Expression',
    hint: 'Creative soul, truth-telling, aesthetic power',
    emoji: '\u{1F3B5}',
    categoryId: 'art-expression',
  },
  {
    label: 'Systems & Strategy',
    hint: 'Digital power, code, tools that matter',
    emoji: '\u{1F4BB}',
    categoryId: 'systems-strategy',
  },
  {
    label: 'DIY & Creation',
    hint: 'Physical builds, handmade goods, crafting',
    emoji: '\u{1F6E0}\u{FE0F}',
    categoryId: 'diy-creation',
  },
  {
    label: 'Metaspace',
    hint: 'Reflections on the journey itself — the why and how',
    emoji: '\u{1F300}',
    categoryId: 'metaspace',
  },
];
---

<PageLayout
  title="About Antonio Rodríguez Martínez"
  description="Father² and stepfather². Builder. In a season of execution, practicing patience, temperance, and leadership through ordinary daily action."
  path="/about"
  contentClass="about-shell max-w-none"
>
  <div class="about-columns">
    <div class="about-columns__main">
      <figure class="about-hero">
        <img
          src="/images/mia-y-yo-anime.avif"
          alt="Antonio Rodríguez Martínez and his daughter Mia, illustrated in anime style."
          class="about-hero__img"
          width={1200}
          height={675}
          loading="eager"
          decoding="async"
        />
      </figure>

      <div class="about-story">
        <p>
          For a long time I confused insight with execution: I could explain things with precision
          but daily life still exposed gaps between what I believed or thought I believed and how I
          actually moved. Naming the gap was super useful but closing it is the real work and where
          I am today.
        </p>
        <p>
          I am a boyfriend, a father to a 6-year-old daughter, stepfather to a 2-year-old and a
          21-year-old, and a stay-at-home remote-working parent of an infant. My beautiful blended
          family is my greatest teacher and inspiration. Leadership for me is practical: patience
          under pressure, temperance when I am tired, and choosing presence over ego.
        </p>
        <p>
          I still build systems: digital, emotional, and relational. I care deeply about code,
          strategy, and craft. I am a technical program manager and developer, not a philosopher
          performing certainty. I write to practice what I claim, and to become reliable in small
          repeated actions.
        </p>
        <p>
          This site is where I test ideas against life. If something I write is true, it should hold
          up in my home, my work, and my relationships. I close these gaps in public, and in private
          (more important), even when nobody is watching (most important). I also write for fun.
          Writing is a valve of escape, a creative output, and part of my art practice. I also write
          to learn a fuckton of things, it's very effective.
        </p>
      </div>

      <section class="about-topics" aria-labelledby="about-topics-heading">
        <h2 id="about-topics-heading" class="about-section-title">What these notes cover</h2>
        <p class="about-topics__intro">
          Working notes from real life, organized as a map rather than a finished system.
        </p>
        <ul class="about-topics__list">
          {
            topics.map((t) => (
              <li class="about-topics__item">
                <span class="about-topics__emoji" aria-hidden="true">
                  {t.emoji}
                </span>
                <span class="about-topics__copy">
                  {t.categoryId ? (
                    <a
                      href={`/category/${t.categoryId}`}
                      class="about-topics__label about-topics__label--link"
                    >
                      {t.label}
                    </a>
                  ) : (
                    <span class="about-topics__label">{t.label}</span>
                  )}
                  <span class="about-topics__hint">{t.hint}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    <aside class="about-columns__rail" aria-label="Site tools, watching, and links">
      <section class="about-rail__section about-tools" aria-labelledby="about-tools-heading">
        <h2 id="about-tools-heading" class="about-rail__heading">On this site</h2>
        <p class="about-tools__text">
          I built a few <strong>meta-tools</strong> to see my own patterns more clearly.{' '}
          <a href="/brain-science">Brain Science</a> charts writing cadence and topics over time.{
            ' '
          }
          <a href="/tag-management">Tag management</a> shows how I file ideas. The{' '}
          <a href="/api/">API docs</a> include Stoic quotes and small utilities I use in the margins.
        </p>
      </section>

      <div class="about-rail__section about-rail__watched">
        <LatestWatched films={letterboxdFilms} profileUrl={profileUrl} />
      </div>
    </aside>
  </div>

  <footer class="about-disclaimer">
    <h2 class="about-disclaimer__title">Disclaimer</h2>
    <p class="about-disclaimer__text">
      The wisdom, practices, and digital craft shared here come from personal experience and
      exploration. None of it is medical, legal, psychological, or professional advice. Please talk
      to qualified people when you need that kind of guidance.
    </p>
  </footer>
</PageLayout>

<style>
  .about-shell {
    padding-bottom: 4rem;
  }

  .about-hero {
    margin: 0 0 1.5rem;
    width: 100%;
    min-width: 0;
  }

  .about-hero__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .about-columns {
    display: block;
  }

  @media (min-width: 1024px) {
    .about-columns {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 22rem);
      gap: 2.5rem 3rem;
      align-items: stretch;
    }
  }

  @media (min-width: 1280px) {
    .about-columns {
      grid-template-columns: minmax(0, 1fr) minmax(0, 26rem);
      gap: 3rem 4rem;
    }
  }

  .about-columns__main {
    min-width: 0;
  }

  .about-columns__rail {
    min-width: 0;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgb(var(--color-border) / 0.85);
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  @media (min-width: 1024px) {
    .about-columns__rail {
      margin-top: 0;
      padding-top: 0;
      border-top: none;
      border-left: 1px solid rgb(var(--color-border) / 0.65);
      padding-left: 2.5rem;
      gap: 2.5rem;
    }
  }

  @media (min-width: 1280px) {
    .about-columns__rail {
      padding-left: 3rem;
      gap: 2.75rem;
    }
  }

  /* Shared rail headings (child components don’t receive parent scoped CSS) */
  :global(.about-rail__heading) {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 1.65rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: rgb(var(--color-text));
    margin: 0 0 0.5rem;
  }

  .about-rail__watched {
    min-width: 0;
  }

  @media (min-width: 1024px) {
    .about-links {
      margin-top: auto;
      padding-top: 2rem;
      border-top: 1px solid rgb(var(--color-border) / 0.55);
    }
  }

  .about-lead {
    margin-bottom: 1.75rem;
  }

  .about-lead__kicker {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgb(var(--color-text-muted));
    margin: 0 0 0.35rem;
  }

  .about-lead__text {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.8vw, 1.85rem);
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.02em;
    color: rgb(var(--color-text));
    margin: 0;
    max-width: 38rem;
  }

  .about-story {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgb(var(--color-text));
    max-width: 44rem;
  }

  .about-story p {
    margin-top: 0;
    margin-bottom: 1.1rem;
  }

  .about-story p:last-child {
    margin-bottom: 0;
  }

  .about-section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: rgb(var(--color-text));
    margin: 0;
  }

  .about-topics {
    margin-top: 3rem;
    padding-top: 2.25rem;
    border-top: 1px solid rgb(var(--color-border) / 0.65);
  }

  .about-topics .about-section-title {
    margin-bottom: 0.5rem;
  }

  .about-topics__intro {
    margin: 0 0 1.25rem;
    font-size: 1rem;
    line-height: 1.65;
    color: rgb(var(--color-text-muted));
    max-width: 40rem;
  }

  .about-topics__list {
    list-style: none;
    margin: 0;
    padding: 0;
    column-count: 1;
    column-gap: 2rem;
  }

  @media (min-width: 640px) {
    .about-topics__list {
      column-count: 2;
    }
  }

  .about-topics__item {
    break-inside: avoid;
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
    line-height: 1.5;
  }

  .about-topics__emoji {
    flex-shrink: 0;
    font-size: 1.1rem;
    line-height: 1.4;
    margin-top: 0.1rem;
  }

  .about-topics__copy {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .about-topics__label {
    font-weight: 600;
    color: rgb(var(--color-text));
  }

  .about-topics__label--link {
    text-decoration: none;
    color: inherit;
    transition: color var(--animation-duration-normal) var(--animation-easing-default);
  }

  .about-topics__label--link:hover {
    color: rgb(var(--color-accent));
  }

  .about-topics__label--link:focus {
    outline: none;
  }

  .about-topics__label--link:focus-visible {
    outline: 2px solid rgb(var(--color-accent));
    outline-offset: 2px;
    border-radius: 2px;
  }

  .about-topics__hint {
    color: rgb(var(--color-text-muted));
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .about-links__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .about-links__item {
    border-bottom: 1px solid rgb(var(--color-border) / 0.4);
  }

  .about-links__item:last-child {
    border-bottom: none;
  }

  .about-links__anchor {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0;
    text-decoration: none;
    color: inherit;
    transition: color var(--animation-duration-normal) var(--animation-easing-default);
  }

  .about-links__anchor:hover .about-links__label {
    color: rgb(var(--color-accent));
  }

  .about-links__anchor:focus {
    outline: none;
  }

  .about-links__anchor:focus-visible {
    outline: 2px solid rgb(var(--color-accent));
    outline-offset: 2px;
  }

  .about-links__emoji {
    flex-shrink: 0;
    font-size: 1.05rem;
    line-height: 1;
    width: 1.5rem;
    text-align: center;
  }

  .about-links__label {
    font-weight: 500;
    font-size: 0.9375rem;
    color: rgb(var(--color-text));
    line-height: 1.4;
  }

  .about-tools {
    margin: 0;
    padding: 0;
    border: none;
  }

  .about-tools__text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgb(var(--color-text-muted));
  }

  .about-tools__text :global(a) {
    color: rgb(var(--color-accent));
    font-weight: 500;
  }

  .about-disclaimer {
    margin-top: 4rem;
    padding-top: 2.25rem;
    border-top: 1px solid rgb(var(--color-border) / 0.85);
    max-width: 42rem;
  }

  .about-disclaimer__title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--color-text-muted));
    margin: 0 0 0.65rem;
  }

  .about-disclaimer__text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgb(var(--color-text-muted));
  }

  @media (prefers-reduced-motion: reduce) {
    .about-links__anchor,
    .about-topics__label--link {
      transition: none;
    }
  }
</style>
