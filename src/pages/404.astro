---
import PageLayout from '../layouts/PageLayout.astro';
import NotFoundQuote from '../components/NotFoundQuote.astro';
import { getAllTags } from '../data/tags';

const existingTags = getAllTags();
---

<PageLayout title="Page not found" description="A random line from the quote archive.">
  <div class="not-prose mx-auto max-w-3xl">
    <NotFoundQuote existingTags={existingTags} />
  </div>
</PageLayout>
