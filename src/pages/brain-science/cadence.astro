---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrainScienceLayout from '../../components/brain-science/BrainScienceLayout.astro';
import BrainScienceNarrativeSummary from '../../components/brain-science/BrainScienceNarrativeSummary.astro';
import TimeSeriesChart from '../../components/brain-science/TimeSeriesChart.astro';
import BarChart from '../../components/brain-science/BarChart.astro';
import {
  getBrainSciencePosts,
  calculateBaseMetrics,
  calculateMonthlyPosts,
  calculateDayOfWeekStats,
  calculateMonthOfYearStats,
  calculateStreakMetrics,
} from '../../utils/brainScience/data';
import {
  generateDynamicInsights,
  calculateObjectiveMetrics,
  scoreToLetterGrade,
  letterGradeToColor,
} from '../../utils/insightGenerator';
import { format, differenceInDays } from 'date-fns';
import { BRAIN_SCIENCE_PAGES } from '../../data/brainScience';

// Get all published posts
const posts = await getBrainSciencePosts();

// Calculate base metrics using shared utilities
const baseMetrics = calculateBaseMetrics(posts);
const firstPostDate = baseMetrics.firstPostDate;
const lastPostDate = baseMetrics.lastPostDate;

// Use shared utilities for calculations
const monthlyPosts = calculateMonthlyPosts(posts, firstPostDate, lastPostDate);
const dayOfWeekStats = calculateDayOfWeekStats(posts);
const monthOfYearStats = calculateMonthOfYearStats(posts);
const streakMetrics = calculateStreakMetrics(posts);

// Extract streak data
const sortedStreaks = streakMetrics.streaks;
const sortedDrySpells = streakMetrics.drySpells;
const currentStreak = streakMetrics.currentStreak;
const longestStreak = streakMetrics.longestStreak;

// Productivity periods (months with most posts)
const productiveMonths = monthlyPosts
  .filter((month) => month.count > 0)
  .sort((a, b) => b.count - a.count)
  .slice(0, 5);

// Recent activity (last 30 days)
const thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
const recentPosts = posts.filter((post) => post.data.pubDate >= thirtyDaysAgo);

// Calculate productivity metrics
const avgPostsPerMonth = Math.round(
  posts.length /
    Math.max(1, differenceInDays(lastPostDate || new Date(), firstPostDate || new Date()) / 30),
);
const consistencyScore =
  sortedStreaks.length / Math.max(1, sortedStreaks.length + sortedDrySpells.length);
const productivityTrend: 'improving' | 'declining' | 'stable' =
  recentPosts.length > avgPostsPerMonth
    ? 'improving'
    : recentPosts.length < avgPostsPerMonth * 0.5
      ? 'declining'
      : 'stable';

// Calculate objective metrics
const objectiveMetrics = calculateObjectiveMetrics(posts);

// Generate dynamic insights
const insightData = {
  totalPosts: posts.length,
  totalWords: posts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0),
  avgWordsPerPost: Math.round(
    posts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0) / posts.length,
  ),
  topTags: Object.entries(
    posts.reduce(
      (acc, post) => {
        post.data.tags?.forEach((tag: string) => {
          acc[tag] = (acc[tag] || 0) + 1;
        });
        return acc;
      },
      {} as Record<string, number>,
    ),
  )
    .sort(([, a], [, b]) => b - a)
    .slice(0, 5)
    .map(([tag, count]) => ({ tag, count })),
  emotionalPosts: 0, // Not calculated for cadence
  growthPosts: 0, // Not calculated for cadence
  complexityTrend: 'stable' as const, // Not calculated for cadence
  productivityTrend: productivityTrend,
  knowledgeAreas: [],
  writingStreaks: sortedStreaks.map((streak) => ({ length: streak.length, days: streak.days })),
  drySpells: sortedDrySpells.map((spell) => ({ days: spell.days })),
  // Add objective metrics
  ...objectiveMetrics,
};

const { insights, summary, balancedAnalysis } = generateDynamicInsights(insightData, 'cadence');

// Prepare time series for posting frequency
const postingFrequencyTimeSeries = {
  labels: monthlyPosts.map((m) => m.label),
  datasets: [
    {
      label: 'Posts Per Month',
      data: monthlyPosts.map((m) => m.count),
      borderColor: 'rgb(var(--color-accent))',
      backgroundColor: 'rgba(var(--color-accent), 0.1)',
    },
  ],
};

// Prepare bar chart for day of week
const dayOfWeekChart = {
  labels: dayOfWeekStats.map((d) => d.shortName),
  datasets: [
    {
      label: 'Posts',
      data: dayOfWeekStats.map((d) => d.count),
      backgroundColor: 'rgba(var(--color-accent), 0.6)',
      borderColor: 'rgb(var(--color-accent))',
    },
  ],
};

// Prepare bar chart for month of year
const monthOfYearChart = {
  labels: monthOfYearStats.map((m) => m.shortName),
  datasets: [
    {
      label: 'Posts',
      data: monthOfYearStats.map((m) => m.count),
      backgroundColor: 'rgba(var(--color-accent), 0.6)',
      borderColor: 'rgb(var(--color-accent))',
    },
  ],
};

// Get page info
const pageInfo = BRAIN_SCIENCE_PAGES.find((p) => p.id === 'cadence');
---

<BaseLayout
  title="Writing Cadence - Brain Science"
  description="Publish dates, streaks (≤7-day gaps), and calendar slices from your archive. Descriptive only."
  path="/brain-science/cadence"
  structuredDataType="website"
>
  <BrainScienceLayout
    currentPage="/brain-science/cadence"
    title={pageInfo?.title || 'Writing Cadence'}
    description="Streaks use a 7-day bridge between posts; everything else is counting and binning by calendar. No claims about creativity or motivation—just timestamps and simple ratios."
  >
    <div
      class="mb-6 flex flex-wrap gap-x-10 gap-y-5 border-b border-[rgb(var(--color-border))]/50 pb-6 md:mb-8 md:gap-x-12 md:pb-8"
    >
      <div title="Longest run with ≤7 days between adjacent posts">
        <div
          class="text-2xl font-semibold text-green-600 tabular-nums md:text-3xl dark:text-green-400"
        >
          {longestStreak}
        </div>
        <div class="text-body-muted text-xs">Longest streak</div>
      </div>
      <div title="Active streak by same rule">
        <div class="text-2xl font-semibold text-[rgb(var(--color-text))] tabular-nums md:text-3xl">
          {currentStreak}
        </div>
        <div class="text-body-muted text-xs">Current streak</div>
      </div>
      <div title="Largest gap between consecutive posts (days)">
        <div class="text-2xl font-semibold text-red-600 tabular-nums md:text-3xl dark:text-red-400">
          {sortedDrySpells[0]?.days ?? 0}
        </div>
        <div class="text-body-muted text-xs">Longest gap (days)</div>
      </div>
      <div title="Posts in rolling last 30 days vs monthly average heuristic">
        <div
          class={`text-2xl font-semibold tabular-nums md:text-3xl ${recentPosts.length > avgPostsPerMonth ? 'text-green-600 dark:text-green-400' : recentPosts.length < avgPostsPerMonth * 0.5 ? 'text-red-600 dark:text-red-400' : 'text-[rgb(var(--color-text))]'}`}
        >
          {recentPosts.length}
        </div>
        <div class="text-body-muted text-xs">Last 30 days (posts)</div>
      </div>
    </div>

    <nav
      class="mb-8 border-b border-dashed border-[rgb(var(--color-border))]/50 pb-4 md:mb-10"
      aria-label="On this page"
    >
      <div class="text-body-muted mb-2 text-[0.65rem] font-semibold tracking-wider uppercase">
        Jump to
      </div>
      <ul class="m-0 flex list-none flex-wrap gap-x-4 gap-y-2 p-0 text-sm">
        <li class="m-0 p-0">
          <a
            href="#monthly"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Monthly</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#calendar"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Weekday / season</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#streaks"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Streaks &amp; gaps</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#balanced"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Consistency grades</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#summary"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Narrative summary</a
          >
        </li>
      </ul>
    </nav>

    <div class="mb-8 border-b border-[rgb(var(--color-border))]/40 pb-8 md:mb-10">
      <h2 class="text-body-muted mb-2 text-sm font-semibold tracking-wide uppercase">
        Cadence ratios (toy)
      </h2>
      <p class="text-body-muted mb-4 max-w-3xl text-xs md:text-sm">
        “Consistency” = streaks ÷ (streaks + dry spells). “Trend” compares last-30-day count to
        average posts/month—coarse, not forecasting.
      </p>
      <table
        class="w-full max-w-lg border-collapse border-t border-b border-[rgb(var(--color-border))] text-sm tabular-nums"
      >
        <tbody>
          <tr class="border-b border-[rgb(var(--color-border))]/35">
            <td class="text-body-muted py-2 pr-4">Streak share</td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]">
              {Math.round(consistencyScore * 100)}%
            </td>
          </tr>
          <tr class="border-b border-[rgb(var(--color-border))]/35">
            <td class="text-body-muted py-2 pr-4">Avg posts / month</td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]"
              >{avgPostsPerMonth}</td
            >
          </tr>
          <tr>
            <td class="text-body-muted py-2 pr-4">30d vs avg (heuristic)</td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))] capitalize">
              {productivityTrend}
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    {/* Monthly Activity Chart */}
    {
      postingFrequencyTimeSeries.labels.length > 0 && (
        <section id="monthly" class="mb-10 scroll-mt-28 md:mb-12">
          <h2 class="mb-4 text-lg font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-xl">
            Monthly publishing frequency
          </h2>
          <p class="text-body-muted mb-6 max-w-3xl text-sm">
            Post count per month over time. Formula: posts_per_month = count(posts where pubDate ∈
            [month_start, month_end])
          </p>
          <TimeSeriesChart
            id="monthly-posting-frequency"
            labels={postingFrequencyTimeSeries.labels}
            datasets={postingFrequencyTimeSeries.datasets}
            title="Posts Published Per Month"
            yAxisLabel="Number of Posts"
          />
        </section>
      )
    }

    <section
      id="calendar"
      class="mb-10 grid scroll-mt-28 grid-cols-1 gap-10 md:mb-12 md:gap-12 lg:grid-cols-2"
    >
      <div>
        <h3 class="mb-2 text-base font-semibold text-[rgb(var(--color-text))] md:text-lg">
          Day of week
        </h3>
        <p class="text-body-muted mb-4 text-xs">
          Post frequency by day of week. Formula: frequency(day) = count(posts where
          day_of_week(pubDate) = day) / total_posts × 100
        </p>
        {
          dayOfWeekChart.labels.length > 0 && (
            <BarChart
              id="day-of-week-chart"
              labels={dayOfWeekChart.labels}
              datasets={dayOfWeekChart.datasets}
              title="Posts by Day of Week"
              yAxisLabel="Post Count"
            />
          )
        }
      </div>

      <div>
        <h3 class="mb-2 text-base font-semibold text-[rgb(var(--color-text))] md:text-lg">
          Month of year
        </h3>
        <p class="text-body-muted mb-4 text-xs">
          Post frequency by month of year. Formula: frequency(month) = count(posts where
          month(pubDate) = month) / total_posts × 100
        </p>
        {
          monthOfYearChart.labels.length > 0 && (
            <BarChart
              id="month-of-year-chart"
              labels={monthOfYearChart.labels}
              datasets={monthOfYearChart.datasets}
              title="Posts by Month of Year"
              yAxisLabel="Post Count"
            />
          )
        }
      </div>
    </section>

    <section id="streaks" class="mb-10 scroll-mt-28 md:mb-12" aria-labelledby="streaks-heading">
      <h2
        id="streaks-heading"
        class="mb-2 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
      >
        Streaks &amp; gaps
      </h2>
      <p class="text-body-muted mb-6 max-w-3xl text-xs md:text-sm">
        Streak = posts chained with ≤7 days between neighbors. Gaps are the complements between
        publications.
      </p>

      <h3 class="text-body-muted mb-3 text-sm font-semibold tracking-wide uppercase">
        Top streaks
      </h3>
      <div
        class="mb-10 divide-y divide-[rgb(var(--color-border))]/40 border-t border-[rgb(var(--color-border))]/40"
      >
        {
          sortedStreaks.slice(0, 10).map((streak, index) => (
            <div class="flex flex-wrap items-baseline justify-between gap-3 py-2.5">
              <div class="min-w-0">
                <span class="text-body-muted mr-2 font-mono text-xs">{index + 1}.</span>
                <span class="text-sm font-medium text-[rgb(var(--color-text))]">
                  {streak.length} posts / {streak.days} days
                </span>
                <span class="text-body-muted mt-0.5 block text-xs sm:mt-0 sm:inline sm:before:content-['_·_']">
                  {format(streak.startDate, 'MMM d, yyyy')} –{' '}
                  {format(streak.endDate, 'MMM d, yyyy')}
                </span>
              </div>
              <div
                class="text-body-muted text-sm tabular-nums"
                title="Mean posts per day across span"
              >
                {Math.round((streak.length / streak.days) * 100) / 100}/day
              </div>
            </div>
          ))
        }
      </div>

      <h3 class="text-body-muted mb-3 text-sm font-semibold tracking-wide uppercase">
        Largest gaps
      </h3>
      <div
        class="mb-10 divide-y divide-[rgb(var(--color-border))]/40 border-t border-[rgb(var(--color-border))]/40"
      >
        {
          sortedDrySpells.slice(0, 5).map((spell, index) => (
            <div class="flex flex-wrap items-baseline justify-between gap-3 py-2.5">
              <div class="min-w-0">
                <span class="text-body-muted mr-2 font-mono text-xs">{index + 1}.</span>
                <span class="text-sm font-medium text-[rgb(var(--color-text))]">
                  {spell.days} days
                </span>
                <span class="text-body-muted mt-0.5 block text-xs sm:mt-0 sm:inline sm:before:content-['_·_']">
                  {format(spell.startDate, 'MMM d, yyyy')} – {format(spell.endDate, 'MMM d, yyyy')}
                </span>
              </div>
              <div class="text-body-muted text-sm tabular-nums">
                ~{Math.round(spell.days / 7)} wk
              </div>
            </div>
          ))
        }
      </div>

      <h3 class="text-body-muted mb-3 text-sm font-semibold tracking-wide uppercase">
        Busiest calendar months (top 5)
      </h3>
      <div class="overflow-x-auto">
        <table
          class="w-full max-w-md border-collapse border-t border-b border-[rgb(var(--color-border))] text-sm tabular-nums"
        >
          <tbody>
            {
              productiveMonths.map((month, index) => (
                <tr class="border-b border-[rgb(var(--color-border))]/35 last:border-0">
                  <td class="text-body-muted py-2 pr-4 font-mono text-xs">{index + 1}</td>
                  <td class="py-2 pr-4 text-[rgb(var(--color-text))]">{month.label}</td>
                  <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]">
                    {month.count}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    <section id="balanced" class="mb-10 scroll-mt-28 md:mb-12">
      <h2 class="mb-2 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl">
        Objective consistency grades
      </h2>
      <p class="text-body-muted mb-6 max-w-3xl text-sm">
        Same abbreviated scores as the hub page—orthogonal to streak math above.
      </p>

      <div class="overflow-x-auto">
        <table
          class="mb-10 w-full max-w-2xl border-collapse border-t border-b border-[rgb(var(--color-border))] text-sm tabular-nums"
        >
          <thead>
            <tr
              class="text-body-muted border-b border-[rgb(var(--color-border))] text-left text-[0.65rem] font-semibold tracking-wider uppercase"
            >
              <th scope="col" class="py-2 pr-4 font-medium">Metric</th>
              <th scope="col" class="py-2 pr-4 font-medium">Score</th>
              <th scope="col" class="py-2 font-medium">Grade</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[rgb(var(--color-border))]/35">
              <td class="py-2.5 pr-4 text-[rgb(var(--color-text))]">Posting regularity</td>
              <td class="text-body-muted py-2.5 pr-4">
                {objectiveMetrics.consistencyMetrics.postingRegularity}/100
              </td>
              <td
                class={`py-2.5 font-semibold ${letterGradeToColor(scoreToLetterGrade(objectiveMetrics.consistencyMetrics.postingRegularity))}`}
              >
                {scoreToLetterGrade(objectiveMetrics.consistencyMetrics.postingRegularity)}
              </td>
            </tr>
            <tr class="border-b border-[rgb(var(--color-border))]/35">
              <td class="py-2.5 pr-4 text-[rgb(var(--color-text))]">Topic consistency</td>
              <td class="text-body-muted py-2.5 pr-4">
                {objectiveMetrics.consistencyMetrics.topicConsistency}/100
              </td>
              <td
                class={`py-2.5 font-semibold ${letterGradeToColor(scoreToLetterGrade(objectiveMetrics.consistencyMetrics.topicConsistency))}`}
              >
                {scoreToLetterGrade(objectiveMetrics.consistencyMetrics.topicConsistency)}
              </td>
            </tr>
            <tr>
              <td class="py-2.5 pr-4 text-[rgb(var(--color-text))]"
                >Length stability (inverse var.)</td
              >
              <td class="text-body-muted py-2.5 pr-4">
                {100 - objectiveMetrics.consistencyMetrics.qualityVariance}/100
              </td>
              <td
                class={`py-2.5 font-semibold ${letterGradeToColor(scoreToLetterGrade(100 - objectiveMetrics.consistencyMetrics.qualityVariance))}`}
              >
                {scoreToLetterGrade(100 - objectiveMetrics.consistencyMetrics.qualityVariance)}
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      {/* Strengths */}
      {
        balancedAnalysis.strengths.length > 0 && (
          <div class="mb-6 md:mb-8">
            <h3 class="mb-4 text-lg font-medium text-[rgb(var(--color-text))] text-green-600 dark:text-green-400">
              ✅ Strengths
            </h3>
            <div class="space-y-3">
              {balancedAnalysis.strengths.map((insight) => (
                <div class="border-b border-[rgb(var(--color-border))] py-3 last:border-b-0">
                  <div class="text-sm text-[rgb(var(--color-text))]" set:html={insight.text} />
                </div>
              ))}
            </div>
          </div>
        )
      }

      {/* Challenges */}
      {
        balancedAnalysis.challenges.length > 0 && (
          <div class="mb-6 md:mb-8">
            <h3 class="mb-4 text-lg font-medium text-[rgb(var(--color-text))] text-red-600 dark:text-red-400">
              ❌ Challenges
            </h3>
            <div class="space-y-3">
              {balancedAnalysis.challenges.map((insight) => (
                <div class="border-b border-[rgb(var(--color-border))] py-3 last:border-b-0">
                  <div class="text-sm text-[rgb(var(--color-text))]" set:html={insight.text} />
                </div>
              ))}
            </div>
          </div>
        )
      }

      {/* Neutral/Objective */}
      {
        balancedAnalysis.neutral.length > 0 && (
          <div class="mb-6 md:mb-8">
            <h3 class="mb-4 text-lg font-medium text-[rgb(var(--color-text))] text-gray-600 dark:text-gray-400">
              ℹ️ Objective Metrics
            </h3>
            <div class="space-y-3">
              {balancedAnalysis.neutral.map((insight) => (
                <div class="border-b border-[rgb(var(--color-border))] py-3 last:border-b-0">
                  <div class="text-sm text-[rgb(var(--color-text))]" set:html={insight.text} />
                </div>
              ))}
            </div>
          </div>
        )
      }
    </section>

    <BrainScienceNarrativeSummary insights={insights} summary={summary} />
  </BrainScienceLayout>
</BaseLayout>
