---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrainScienceLayout from '../../components/brain-science/BrainScienceLayout.astro';
import TimeSeriesChart from '../../components/brain-science/TimeSeriesChart.astro';
import BarChart from '../../components/brain-science/BarChart.astro';
import { getBrainSciencePosts } from '../../utils/brainScience/data';
import { getTagWeight } from '../../data/tags';
import { endOfQuarter, eachQuarterOfInterval } from 'date-fns';
import { generateDynamicInsights, calculateObjectiveMetrics } from '../../utils/insightGenerator';
import { BRAIN_SCIENCE_PAGES } from '../../data/brainScience';

// Get all published posts
const posts = await getBrainSciencePosts();

// Sort posts by date
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Content evolution analysis
const contentEvolution = posts.map((post) => {
  const content = post.body || '';
  const wordCount = content.split(/\s+/).length;
  const paragraphCount = content.split('\n\n').length;
  const sentenceCount = content.split(/[.!?]+/).length - 1;
  const averageSentenceLength = sentenceCount > 0 ? Math.round(wordCount / sentenceCount) : 0;

  // Calculate complexity score
  const syllableCount = content
    .toLowerCase()
    .replace(/[^a-z]/g, '')
    .split('')
    .filter((char) => 'aeiou'.includes(char)).length;
  const fleschScore =
    sentenceCount > 0
      ? Math.round(
          206.835 - 1.015 * (wordCount / sentenceCount) - 84.6 * (syllableCount / wordCount),
        )
      : 0;

  // Calculate intellectual depth indicators
  const intellectualWords = [
    'because',
    'therefore',
    'however',
    'although',
    'nevertheless',
    'furthermore',
    'moreover',
    'consequently',
    'thus',
    'hence',
    'accordingly',
    'similarly',
    'conversely',
    'meanwhile',
    'subsequently',
    'previously',
    'initially',
    'ultimately',
    'fundamentally',
    'essentially',
  ];
  const intellectualWordCount = intellectualWords.reduce((count, word) => {
    const regex = new RegExp(`\\b${word}\\b`, 'gi');
    return count + (content.match(regex) || []).length;
  }, 0);

  // Calculate curiosity indicators
  const curiosityWords = [
    'wonder',
    'curious',
    'question',
    'explore',
    'discover',
    'investigate',
    'examine',
    'analyze',
    'study',
    'research',
    'learn',
    'understand',
    'figure out',
    'find out',
    'look into',
    'dive into',
    'explore',
    'uncover',
    'reveal',
    'unveil',
  ];
  const curiosityCount = curiosityWords.reduce((count, word) => {
    const regex = new RegExp(`\\b${word}\\b`, 'gi');
    return count + (content.match(regex) || []).length;
  }, 0);

  // Calculate wisdom indicators
  const wisdomWords = [
    'experience',
    'learned',
    'realized',
    'understood',
    'discovered',
    'found',
    'came to',
    'figured out',
    'worked out',
    'determined',
    'concluded',
    'decided',
    'chose',
    'opted',
    'selected',
    'preferred',
    'valued',
    'appreciated',
    'recognized',
    'acknowledged',
  ];
  const wisdomCount = wisdomWords.reduce((count, word) => {
    const regex = new RegExp(`\\b${word}\\b`, 'gi');
    return count + (content.match(regex) || []).length;
  }, 0);

  return {
    title: post.data.title,
    slug: post.id,
    date: post.data.pubDate,
    body: content,
    wordCount,
    paragraphCount,
    sentenceCount,
    averageSentenceLength,
    fleschScore,
    intellectualWordCount,
    curiosityCount,
    wisdomCount,
    readingTime: (() => {
      if (post.data.minutesRead && typeof post.data.minutesRead === 'string') {
        // Extract minutes from "X min read" format
        const match = post.data.minutesRead.match(/(\d+)/);
        return match ? parseInt(match[1]) : Math.ceil(wordCount / 200);
      }
      return Math.ceil(wordCount / 200);
    })(),
    tags: post.data.tags || [],
    categories: post.data.category || [],
    complexityScore: fleschScore + wordCount / 100 + paragraphCount * 2,
    intellectualDepth: intellectualWordCount + curiosityCount + wisdomCount + wordCount / 50,
  };
});

// Topic progression over time (by quarters)
const quarters = [];
const currentYear = new Date().getFullYear();
const startYear = sortedPosts[sortedPosts.length - 1]?.data.pubDate.getFullYear() || currentYear;

for (let year = startYear; year <= currentYear; year++) {
  for (let quarter = 1; quarter <= 4; quarter++) {
    const quarterStart = new Date(year, (quarter - 1) * 3, 1);
    const quarterEnd = new Date(year, quarter * 3, 0);

    const quarterPosts = posts.filter(
      (post) => post.data.pubDate >= quarterStart && post.data.pubDate <= quarterEnd,
    );

    if (quarterPosts.length > 0) {
      const quarterTags = quarterPosts.reduce(
        (acc, post) => {
          post.data.tags?.forEach((tag) => {
            acc[tag] = (acc[tag] || 0) + 1;
          });
          return acc;
        },
        {} as Record<string, number>,
      );

      const quarterCategories = quarterPosts.reduce(
        (acc, post) => {
          post.data.category?.forEach((cat) => {
            acc[cat] = (acc[cat] || 0) + 1;
          });
          return acc;
        },
        {} as Record<string, number>,
      );

      quarters.push({
        year,
        quarter,
        label: `Q${quarter} ${year}`,
        posts: quarterPosts.length,
        topTags: Object.entries(quarterTags)
          .sort(([, a], [, b]) => b - a)
          .slice(0, 5)
          .map(([tag, count]) => ({ tag, count, weight: getTagWeight(tag) })),
        topCategories: Object.entries(quarterCategories)
          .sort(([, a], [, b]) => b - a)
          .slice(0, 3)
          .map(([cat, count]) => ({ cat, count })),
        avgWordCount: Math.round(
          quarterPosts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0) /
            quarterPosts.length,
        ),
        avgComplexity: Math.round(
          quarterPosts.reduce((sum, post) => {
            const content = post.body || '';
            const wordCount = content.split(/\s+/).length;
            const sentenceCount = content.split(/[.!?]+/).length - 1;
            const syllableCount = content
              .toLowerCase()
              .replace(/[^a-z]/g, '')
              .split('')
              .filter((char) => 'aeiou'.includes(char)).length;
            const fleschScore =
              sentenceCount > 0
                ? Math.round(
                    206.835 -
                      1.015 * (wordCount / sentenceCount) -
                      84.6 * (syllableCount / wordCount),
                  )
                : 0;
            return sum + fleschScore;
          }, 0) / quarterPosts.length,
        ),
      });
    }
  }
}

// Writing style evolution
const styleEvolution = contentEvolution
  .sort((a, b) => a.date.valueOf() - b.date.valueOf())
  .map((post, index) => ({
    ...post,
    trendIndex: index,
    period:
      index < contentEvolution.length / 3
        ? 'Early'
        : index < (contentEvolution.length * 2) / 3
          ? 'Middle'
          : 'Recent',
  }));

// Complexity trends
const complexityTrends = styleEvolution.reduce(
  (acc, post) => {
    const period = post.period;
    if (!acc[period]) {
      acc[period] = [];
    }
    acc[period].push(post);
    return acc;
  },
  {} as Record<string, typeof styleEvolution>,
);

const periodStats = Object.entries(complexityTrends).map(([period, posts]) => ({
  period,
  avgWordCount: Math.round(posts.reduce((sum, post) => sum + post.wordCount, 0) / posts.length),
  avgComplexity: Math.round(posts.reduce((sum, post) => sum + post.fleschScore, 0) / posts.length),
  avgIntellectualDepth: Math.round(
    posts.reduce((sum, post) => sum + post.intellectualDepth, 0) / posts.length,
  ),
  avgCuriosityCount: Math.round(
    posts.reduce((sum, post) => sum + post.curiosityCount, 0) / posts.length,
  ),
  avgWisdomCount: Math.round(posts.reduce((sum, post) => sum + post.wisdomCount, 0) / posts.length),
  avgReadingTime: Math.round(posts.reduce((sum, post) => sum + post.readingTime, 0) / posts.length),
  postCount: posts.length,
}));

// Most evolved topics (topics that have grown in frequency over time)
interface TopicGrowth {
  tag: string;
  earlyCount: number;
  recentCount: number;
  growth: number;
  growthRate: number;
}

const topicGrowth: Record<string, TopicGrowth> = {};
const earlyQuarters = quarters.slice(0, Math.floor(quarters.length / 3));
const recentQuarters = quarters.slice(-Math.floor(quarters.length / 3));

// Compare early vs recent topic frequency
const allTags = new Set<string>();
quarters.forEach((quarter) => quarter.topTags.forEach((tag) => allTags.add(tag.tag)));

allTags.forEach((tag) => {
  const earlyCount = earlyQuarters.reduce(
    (sum, quarter) => sum + (quarter.topTags.find((t) => t.tag === tag)?.count || 0),
    0,
  );
  const recentCount = recentQuarters.reduce(
    (sum, quarter) => sum + (quarter.topTags.find((t) => t.tag === tag)?.count || 0),
    0,
  );

  if (earlyCount > 0 || recentCount > 0) {
    topicGrowth[tag] = {
      tag,
      earlyCount,
      recentCount,
      growth: recentCount - earlyCount,
      growthRate:
        earlyCount > 0
          ? ((recentCount - earlyCount) / earlyCount) * 100
          : recentCount > 0
            ? 100
            : 0,
    };
  }
});

const growingTopics = Object.values(topicGrowth)
  .sort((a, b) => b.growthRate - a.growthRate)
  .slice(0, 10);

const decliningTopics = Object.values(topicGrowth)
  .sort((a, b) => a.growthRate - b.growthRate)
  .slice(0, 10);

// Writing maturity indicators
const maturityIndicators = contentEvolution.map((post) => {
  const content = post.body || '';
  const hasCode = /```[\s\S]*```/.test(content) || /`[^`]+`/.test(content);
  const hasLinks = /\[.*\]\(https?:\/\/.*\)/.test(content) || /https?:\/\/[^\s]+/.test(content);
  const hasImages = /!\[.*\]\(.*\)/.test(content);
  const hasQuotes = />\s+.+/.test(content);
  const hasQuestions = /\?/g.test(content);
  const hasExamples = /for example|such as|like|including|e\.g\.|i\.e\./gi.test(content);

  return {
    ...post,
    hasCode,
    hasLinks,
    hasImages,
    hasQuotes,
    hasQuestions,
    hasExamples,
    maturityScore:
      (hasCode ? 2 : 0) +
      (hasLinks ? 1 : 0) +
      (hasImages ? 1 : 0) +
      (hasQuotes ? 1 : 0) +
      (hasQuestions ? 1 : 0) +
      (hasExamples ? 1 : 0) +
      (post.wordCount > 1000 ? 2 : 0) +
      (post.intellectualDepth > 10 ? 2 : 0),
  };
});

const avgMaturityScore = Math.round(
  maturityIndicators.reduce((sum, post) => sum + post.maturityScore, 0) / maturityIndicators.length,
);

// Heuristic summaries (counts & formulas — not measures of IQ or “truth”)
const intellectualInsights = [
  {
    insight: 'Language-heuristic totals shifted between early and recent writing',
    evidence: `${periodStats[periodStats.length - 1]?.avgIntellectualDepth || 0} vs ${periodStats[0]?.avgIntellectualDepth || 0} avg composite (word-list hits + word count term)`,
    impact: 'High',
    reflection: 'Any change here can be length or vocabulary habits—not automatically “depth.”',
  },
  {
    insight: 'Curiosity word-list hits averaged per post shifted',
    evidence: `Recent slice: ~${periodStats[periodStats.length - 1]?.avgCuriosityCount || 0} matches per post (curated “wonder / explore / research …” stems in raw Markdown)`,
    impact: 'High',
    reflection: 'Frequency can reflect topic or habit—not intrinsically ‘more curious.’',
  },
  {
    insight: 'Reflective language stems averaged per post shifted',
    evidence: `Recent slice: ~${periodStats[periodStats.length - 1]?.avgWisdomCount || 0} matches per post (curated “learned / realized / chose …” stems)`,
    impact: 'Medium',
    reflection: 'These are rhetorical tics you can game; treat as texture, not virtue.',
  },
  {
    insight: 'Your knowledge areas are expanding',
    evidence: `${growingTopics.length} topics growing vs ${decliningTopics.length} declining`,
    impact: 'High',
    reflection: 'Which new areas of knowledge excite you most?',
  },
];

// Calculate objective metrics
const objectiveMetrics = calculateObjectiveMetrics(posts);

// Generate dynamic insights
const insightData = {
  totalPosts: posts.length,
  totalWords: posts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0),
  avgWordsPerPost: Math.round(
    posts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0) / posts.length,
  ),
  topTags: Object.entries(
    posts.reduce(
      (acc, post) => {
        post.data.tags?.forEach((tag: string) => {
          acc[tag] = (acc[tag] || 0) + 1;
        });
        return acc;
      },
      {} as Record<string, number>,
    ),
  )
    .sort(([, a], [, b]) => b - a)
    .slice(0, 5)
    .map(([tag, count]) => ({ tag, count })),
  emotionalPosts: 0, // Not calculated for evolution
  growthPosts: 0, // Not calculated for evolution
  complexityTrend:
    (() => {
      const early = periodStats[0]?.avgComplexity ?? NaN;
      const recent = periodStats[periodStats.length - 1]?.avgComplexity ?? NaN;
      if (Number.isNaN(early) || Number.isNaN(recent) || periodStats.length < 2) return 'stable' as const;
      if (Math.abs(recent - early) < 3) return 'stable' as const;
      /* Flesch: higher score ≈ easier text */
      return recent > early ? ('increasing' as const) : ('decreasing' as const);
    })(),
  productivityTrend: 'stable' as const, // Not calculated for evolution
  knowledgeAreas: [],
  writingStreaks: [],
  drySpells: [],
  // Add objective metrics
  ...objectiveMetrics,
};

const { insights, summary } = generateDynamicInsights(insightData, 'evolution');

// Prepare time series data for complexity evolution
const sortedContentEvolution = contentEvolution.sort((a, b) => a.date.valueOf() - b.date.valueOf());
const firstDate = sortedContentEvolution[0]?.date || new Date();
const lastDate = sortedContentEvolution[sortedContentEvolution.length - 1]?.date || new Date();
const complexityQuarters = eachQuarterOfInterval({ start: firstDate, end: lastDate });

const complexityTimeSeries = complexityQuarters
  .map((quarterStart) => {
    const quarterEnd = endOfQuarter(quarterStart);
    const quarterLabel = `Q${Math.floor(quarterStart.getMonth() / 3) + 1} ${quarterStart.getFullYear()}`;

    const quarterPosts = sortedContentEvolution.filter(
      (post) => post.date >= quarterStart && post.date <= quarterEnd,
    );

    const avgComplexity =
      quarterPosts.length > 0
        ? quarterPosts.reduce((sum, post) => sum + post.fleschScore, 0) / quarterPosts.length
        : 0;

    const avgIntellectualDepth =
      quarterPosts.length > 0
        ? quarterPosts.reduce((sum, post) => sum + post.intellectualDepth, 0) / quarterPosts.length
        : 0;

    return {
      label: quarterLabel,
      complexity: Math.round(avgComplexity * 100) / 100,
      intellectualDepth: Math.round(avgIntellectualDepth * 100) / 100,
    };
  })
  .filter((q) => q.complexity > 0 || q.intellectualDepth > 0);

// Prepare bar chart for period comparison
const periodComparisonChart = {
  labels: periodStats.map((p) => p.period),
  datasets: [
    {
      label: 'Avg Word Count',
      data: periodStats.map((p) => (isNaN(p.avgWordCount) ? 0 : p.avgWordCount)),
      backgroundColor: 'rgba(59, 130, 246, 0.6)',
      borderColor: 'rgb(59, 130, 246)',
    },
    {
      label: 'Avg Flesch reading ease',
      data: periodStats.map((p) => (isNaN(p.avgComplexity) ? 0 : p.avgComplexity)),
      backgroundColor: 'rgba(147, 51, 234, 0.6)',
      borderColor: 'rgb(147, 51, 234)',
    },
    {
      label: 'Avg word-pattern composite',
      data: periodStats.map((p) => (isNaN(p.avgIntellectualDepth) ? 0 : p.avgIntellectualDepth)),
      backgroundColor: 'rgba(34, 197, 94, 0.6)',
      borderColor: 'rgb(34, 197, 94)',
    },
  ],
};

// Get page info
const pageInfo = BRAIN_SCIENCE_PAGES.find((p) => p.id === 'evolution');
---

<BaseLayout
  title="Intellectual Growth Analytics - Brain Science"
  description="Readability (Flesch) and word-pattern heuristics over time from post bodies—experimental signals, not IQ or quality scores."
  path="/brain-science/evolution"
  structuredDataType="website"
>
  <BrainScienceLayout
    currentPage="/brain-science/evolution"
    title={pageInfo?.title || 'Intellectual Growth Analytics'}
    description="Readability (Flesch) and word-count heuristics computed from post bodies—signals for how writing changes, not scores of intelligence."
  >
    {/* Intellectual Growth Metrics */}
    <div
      class="mb-8 grid grid-cols-2 gap-4 md:mb-10 md:grid-cols-2 md:gap-6 lg:mb-12 lg:grid-cols-4"
    >
      <div
        class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4 md:p-6"
      >
        <div
          class="mb-1 text-xl font-bold text-[rgb(var(--color-text))] md:mb-2 md:text-2xl"
          title="Number of quarters analyzed (3-month periods with published posts)"
        >
          {quarters.length}
        </div>
        <div class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm">Quarters Analyzed</div>
        <div class="mt-1 text-xs text-blue-500">📊 Time Periods</div>
      </div>
      <div
        class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4 md:p-6"
      >
        <div
          class="mb-1 text-xl font-bold text-[rgb(var(--color-text))] md:mb-2 md:text-2xl"
          title="Average maturity score across all posts (based on code, links, images, quotes, and word count)"
        >
          {avgMaturityScore}
        </div>
        <div class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm">Avg Maturity Score</div>
        <div class="mt-1 text-xs text-green-500">🧠 Format mix (heuristic)</div>
      </div>
      <div
        class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4 md:p-6"
      >
        <div
          class="mb-1 text-xl font-bold text-[rgb(var(--color-text))] md:mb-2 md:text-2xl"
          title="Number of topics that have increased in frequency over time"
        >
          {growingTopics.length}
        </div>
        <div class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm">Growing Topics</div>
        <div class="mt-1 text-xs text-green-500">📈 Expanding Interests</div>
      </div>
      <div
        class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4 md:p-6"
      >
        <div
          class="mb-1 text-xl font-bold text-[rgb(var(--color-text))] md:mb-2 md:text-2xl"
          title="Number of topics that have decreased in frequency over time"
        >
          {decliningTopics.length}
        </div>
        <div class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm">Declining Topics</div>
        <div class="mt-1 text-xs text-red-500">📉 Shifting Focus</div>
      </div>
    </div>

    {/* Reading ease + heuristic index (formerly mislabeled “complexity / intellectual depth”) */}
    {
      complexityTimeSeries.length > 0 && (
        <div class="mb-8 md:mb-10 lg:mb-12">
          <h2 class="mb-3 text-lg font-semibold text-[rgb(var(--color-text))] md:mb-4 md:text-xl">
            📈 Readability vs. heuristic language index (by quarter)
          </h2>
          <p class="mb-4 max-w-3xl text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">
            This chart is exploratory. Lines are aggregated from Markdown bodies only—titles, headings,
            and frontmatter quirks can skew counts. Useful for spotting drift in length and wording,
            not for ranking how “deep” thinking is.
          </p>

          <div
            class="mb-6 space-y-4 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))]/60 p-4 md:p-6"
          >
            <div>
              <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-[rgb(var(--color-text))]">
                1 · Flesch reading ease (purple line)
              </h3>
              <p class="mb-0 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">
                Roughly measures how simple sentences and syllable load are compared to benchmark
                English. <strong class="font-semibold text-[rgb(var(--color-text))]"
                  >Higher = easier reading by formula</strong
                > (short words, shorter sentences)—not harder or “more intellectual.” Typical published
                blog range is often roughly 30–70. Here syllables are <em>estimated</em> by counting
                vowels, so scores are indicative only (see bottom “Formulas” for the expression).
              </p>
            </div>
            <div>
              <h3 class="mb-2 text-sm font-semibold uppercase tracking-wide text-[rgb(var(--color-text))]">
                2 · Word-pattern composite (green line — experiment)
              </h3>
              <p class="mb-2 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">
                A toy index in code: occurrences of curated “discourse,” “curiosity,” and reflection
                word lists, plus <code class="rounded bg-[rgb(var(--color-bg-alt))] px-1 py-0.5 text-xs font-mono"
                  >words ÷ 50</code
                >
                baked in so longer posts mechanically score higher regardless of merit. Interpret as “how
                often these lexical buckets fire,” not cognition or truth.
              </p>
              <p class="mb-0 text-xs leading-relaxed text-[rgb(var(--color-text-muted))] md:text-sm">
                <strong class="text-[rgb(var(--color-text))]">Combined post-level formula:</strong>
                (transition-like matches + curiosity stems + reflective stems) +
                round(word&nbsp;count&nbsp;/&nbsp;50). Charts show the <strong>mean per calendar quarter</strong> across
                posts.
              </p>
            </div>
            <p class="mb-0 border-t border-[rgb(var(--color-border))]/40 pt-4 text-xs text-[rgb(var(--color-text-muted))] md:text-sm">
              <strong class="text-[rgb(var(--color-text))]">Mixed scales:</strong> Flesch and the heuristic
              share one axis—use it for directional comparison, not to equate magnitude between the two series.
            </p>
          </div>

          <TimeSeriesChart
            id="complexity-evolution"
            labels={complexityTimeSeries.map((q) => q.label)}
            datasets={[
              {
                label: 'Flesch reading ease (avg)',
                data: complexityTimeSeries.map((q) => (isNaN(q.complexity) ? 0 : q.complexity)),
                borderColor: 'rgb(147, 51, 234)',
                backgroundColor: 'rgba(147, 51, 234, 0.1)',
              },
              {
                label: 'Word-pattern composite (avg)',
                data: complexityTimeSeries.map((q) =>
                  isNaN(q.intellectualDepth) ? 0 : q.intellectualDepth,
                ),
                borderColor: 'rgb(34, 197, 94)',
                backgroundColor: 'rgba(34, 197, 94, 0.1)',
              },
            ]}
            title="Quarterly readability & heuristic averages"
            yAxisLabel="See definitions above — mixed units"
          />
        </div>
      )
    }

    {/* Period Comparison */}
    {
      periodComparisonChart.labels.length > 0 && (
        <div class="mb-8 md:mb-10 lg:mb-12">
          <h2 class="mb-4 text-lg font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-xl">
            📊 Metrics comparison by period
          </h2>
          <p class="mb-6 max-w-3xl text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">
            Each bar group splits the archive into thirds by publication order (<strong class="font-medium text-[rgb(var(--color-text))]"
              >Early / Middle / Recent</strong
            >). Means mix <strong class="font-medium text-[rgb(var(--color-text))]">word count</strong>, <strong class="font-medium text-[rgb(var(--color-text))]">average Flesch reading ease per post</strong>, and <strong class="font-medium text-[rgb(var(--color-text))]"
              >the word-pattern composite</strong
            >
            ({' '}
            <em>different units stacked for contrast—eyeball deltas, don’t ratio them</em>).
          </p>
          <BarChart
            id="period-comparison-chart"
            labels={periodComparisonChart.labels}
            datasets={periodComparisonChart.datasets}
            title="Writing Metrics by Period"
            yAxisLabel="Mixed units — see section intro"
          />
        </div>
      )
    }

    {/* Period heuristics (counts, not cognition) */}
    <div class="mb-6 md:mb-8 lg:mb-10">
      <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
        📊 Signals by writing period
      </h3>
      <p class="mb-6 max-w-3xl text-xs leading-relaxed text-[rgb(var(--color-text-muted))] md:text-sm">
        Short notes below compare rough metrics between <strong class="text-[rgb(var(--color-text))]"
          >Early / Middle / Recent</strong
        > slices of the archive. “Significance” is an informal weight for the dashboard, not statistical
        testing.
      </p>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-6">
        {
          intellectualInsights.map((insight, index) => (
            <div class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4">
              <div class="mb-3 flex items-center gap-3">
                <div class="text-base font-bold text-[rgb(var(--color-accent))] md:text-lg">
                  #{index + 1}
                </div>
                <span
                  class={`rounded px-2 py-1 text-xs ${
                    insight.impact === 'High'
                      ? 'bg-green-100 text-green-800 dark:bg-green-900/20 dark:text-green-400'
                      : insight.impact === 'Medium'
                        ? 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/20 dark:text-yellow-400'
                        : 'bg-blue-100 text-blue-800 dark:bg-blue-900/20 dark:text-blue-400'
                  }`}
                >
                  {insight.impact} emphasis
                </span>
              </div>
              <div class="mb-2 text-sm font-medium text-[rgb(var(--color-text))]">
                {insight.insight}
              </div>
              <div class="mb-0 text-xs leading-relaxed text-[rgb(var(--color-text-muted))]">
                {insight.evidence}
              </div>
              <div class="mt-3 border-t border-[rgb(var(--color-border))]/30 pt-3 text-xs italic text-[rgb(var(--color-text-muted))]">
                {insight.reflection}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Thinking Style Metrics by Period */}
    <div
      class="mb-6 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4 md:mb-8 md:p-6 lg:mb-10"
    >
      <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
        📊 Writing Metrics by Period
      </h3>
      <p class="mb-4 text-xs leading-relaxed text-[rgb(var(--color-text-muted))] md:text-sm">
        Per-period <strong class="font-medium text-[rgb(var(--color-text))]">means</strong> on the raw post
        body. Higher Flesch = easier wording by formula (see definitions above).
      </p>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 md:gap-6 lg:grid-cols-3">
        {
          periodStats.map((period) => (
            <div class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] p-4">
              <div class="mb-3 text-base font-semibold text-[rgb(var(--color-text))] md:mb-4 md:text-lg">
                {period.period} Period
              </div>
              <div class="space-y-2 md:space-y-3">
                <div class="flex justify-between">
                  <span class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm">
                    Avg Words:
                  </span>
                  <span
                    class="text-xs font-medium text-[rgb(var(--color-text))] md:text-sm"
                    title={`Average word count per post in ${period.period} period`}
                  >
                    {period.avgWordCount}
                  </span>
                </div>
                <div class="flex justify-between gap-3">
                  <span
                    class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm"
                    title="Avg Flesch reading ease across posts this period — higher tends to mean simpler wording"
                  >
                    Flesch ease:
                  </span>
                  <span
                    class={`text-xs font-medium md:text-sm ${
                      period.avgComplexity >=
                      Math.max(...periodStats.map((p) => p.avgComplexity)) * 0.8
                        ? 'text-green-500'
                        : period.avgComplexity >=
                            Math.max(...periodStats.map((p) => p.avgComplexity)) * 0.5
                          ? 'text-blue-500'
                          : period.avgComplexity >=
                              Math.max(...periodStats.map((p) => p.avgComplexity)) * 0.2
                            ? 'text-yellow-500'
                            : 'text-red-500'
                    }`}
                    title={`Average Flesch reading ease score in ${period.period} period (higher = easier to read)`}
                  >
                    {period.avgComplexity}
                  </span>
                </div>
                <div class="flex justify-between gap-3">
                  <span
                    class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm"
                    title="Composite: transition + curiosity + reflective word-list hits + word count bonus (see chart section)"
                  >
                    Word-pattern Σ:
                  </span>
                  <span
                    class="text-xs font-medium text-[rgb(var(--color-text))] md:text-sm"
                    title={`Average word-pattern composite score in ${period.period} period`}
                  >
                    {period.avgIntellectualDepth}
                  </span>
                </div>
                <div class="flex justify-between">
                  <span
                    class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm"
                    title="Avg count per post of curated ‘curiosity / exploration’ stems in markdown body"
                  >
                    Curiosity stems:
                  </span>
                  <span
                    class="text-xs font-medium text-[rgb(var(--color-text))] md:text-sm"
                    title={`Average curiosity stems per post in ${period.period}`}
                  >
                    {period.avgCuriosityCount}
                  </span>
                </div>
                <div class="flex justify-between">
                  <span
                    class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm"
                    title="Avg count per post of curated reflective / decision language stems"
                  >
                    Reflective stems:
                  </span>
                  <span
                    class="text-xs font-medium text-[rgb(var(--color-text))] md:text-sm"
                    title={`Average reflective stems per post in ${period.period}`}
                  >
                    {period.avgWisdomCount}
                  </span>
                </div>
                <div class="flex justify-between">
                  <span class="text-xs text-[rgb(var(--color-text-muted))] md:text-sm">
                    Writings:
                  </span>
                  <span
                    class="text-xs font-medium text-[rgb(var(--color-text))] md:text-sm"
                    title={`Number of writings in ${period.period} period`}
                  >
                    {period.postCount}
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Topic Growth vs Decline Analysis */}
    <div class="mb-6 grid grid-cols-1 gap-6 md:mb-8 md:gap-8 lg:mb-10 lg:grid-cols-2">
      <div>
        <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
          📈 Topics with Increasing Frequency
        </h3>
        <p class="mb-4 text-xs text-[rgb(var(--color-text-muted))]">
          Topics showing positive growth rate. Formula: growth_rate = ((recent_count - early_count)
          / early_count) × 100
        </p>
        <div class="space-y-4">
          {
            growingTopics.map((topic, index) => (
              <div class="flex items-center justify-between rounded-lg bg-[rgb(var(--color-bg))] p-3">
                <div class="flex items-center gap-3">
                  <div
                    class={`text-lg font-bold ${
                      index === 0
                        ? 'text-yellow-500'
                        : index === 1
                          ? 'text-gray-400'
                          : index === 2
                            ? 'text-amber-600'
                            : 'text-green-500'
                    }`}
                  >
                    {index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : `#${index + 1}`}
                  </div>
                  <div>
                    <div class="text-sm font-medium text-[rgb(var(--color-text))]">{topic.tag}</div>
                    <div class="text-xs text-[rgb(var(--color-text-muted))]">
                      {topic.earlyCount} → {topic.recentCount} writings
                    </div>
                  </div>
                </div>
                <div
                  class="text-sm font-medium text-green-500"
                  title={`Growth rate: ${Math.round(topic.growthRate)}% increase from early to recent periods`}
                >
                  +{Math.round(topic.growthRate)}%
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
          📉 Topics with Decreasing Frequency
        </h3>
        <p class="mb-4 text-xs text-[rgb(var(--color-text-muted))]">
          Topics showing negative growth rate. Formula: growth_rate = ((recent_count - early_count)
          / early_count) × 100
        </p>
        <div class="space-y-4">
          {
            decliningTopics.map((topic, index) => (
              <div class="flex items-center justify-between rounded-lg bg-[rgb(var(--color-bg))] p-3">
                <div class="flex items-center gap-3">
                  <div class="text-lg font-bold text-red-500">#{index + 1}</div>
                  <div>
                    <div class="text-sm font-medium text-[rgb(var(--color-text))]">{topic.tag}</div>
                    <div class="text-xs text-[rgb(var(--color-text-muted))]">
                      {topic.earlyCount} → {topic.recentCount} writings
                    </div>
                  </div>
                </div>
                <div
                  class="text-sm font-medium text-red-500"
                  title={`Decline rate: ${Math.round(topic.growthRate)}% decrease from early to recent periods`}
                >
                  {Math.round(topic.growthRate)}%
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* Topic Evolution Timeline */}
    <div class="mb-6 md:mb-8 lg:mb-10">
      <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
        📅 Topic Frequency Timeline by Quarter
      </h3>
      <p class="mb-4 text-xs leading-relaxed text-[rgb(var(--color-text-muted))] md:text-sm">
        Per quarter: counts, average words, and average Flesch reading ease (Markdown body only). Flesch uses
        vowel-based syllable guesses, so treat as directional.
      </p>
      <div class="space-y-6">
        {
          quarters.slice(-8).map((quarter) => (
            <div class="rounded-lg bg-[rgb(var(--color-bg))] p-4">
              <div class="mb-3 flex items-center justify-between">
                <h4 class="text-sm font-medium text-[rgb(var(--color-text))]">{quarter.label}</h4>
                <div
                  class="max-w-[min(100%,20rem)] text-right text-xs leading-snug text-[rgb(var(--color-text-muted))] md:max-w-none"
                  title={`${quarter.posts} posts · ${quarter.avgWordCount} avg words · ${quarter.avgComplexity} avg Flesch ease (higher = simpler by formula)`}
                >
                  {quarter.posts} posts · {quarter.avgWordCount} words · Flesch ~{quarter.avgComplexity}
                </div>
              </div>
              <div class="mb-3">
                <div class="mb-2 text-xs text-[rgb(var(--color-text-muted))]">Top Topics:</div>
                <div class="flex flex-wrap gap-2">
                  {quarter.topTags.map((tag) => (
                    <span
                      class="rounded bg-[rgb(var(--color-accent))] px-2 py-1 text-xs text-white"
                      title={`${tag.count} writings tagged with "${tag.tag}" in ${quarter.label}`}
                    >
                      {tag.tag} ({tag.count})
                    </span>
                  ))}
                </div>
              </div>
              <div>
                <div class="mb-2 text-xs text-[rgb(var(--color-text-muted))]">Categories:</div>
                <div class="flex flex-wrap gap-2">
                  {quarter.topCategories.map((cat) => (
                    <span
                      class="rounded border bg-[rgb(var(--color-bg-secondary))] px-2 py-1 text-xs text-[rgb(var(--color-text))]"
                      title={`${cat.count} writings in "${cat.cat}" category in ${quarter.label}`}
                    >
                      {cat.cat} ({cat.count})
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    {/* Writing Maturity */}
    <div class="mb-6 md:mb-8 lg:mb-10">
      <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
        📊 Writing Maturity Metrics
      </h3>
      <p class="mb-4 text-xs leading-relaxed text-[rgb(var(--color-text-muted))] md:text-sm">
        “Maturity” here is a naive checklist on the Markdown body:<br />
        <code class="mt-1 inline-block rounded bg-[rgb(var(--color-bg-alt))] px-2 py-1 text-[0.7rem] font-mono whitespace-pre-wrap"
          >(code fences / inline code ? 2 : 0) + (URLs ? 1 : 0) + (images ? 1 : 0) + (blockquotes ? 1 : 0)
+ (? in body ? 1 : 0) + (e.g./such as cues ? 1 : 0) + (words &gt; 1000 ? 2 : 0)
+ (word-pattern composite &gt; 10 ? 2 : 0)</code
        >
      </p>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-lg bg-[rgb(var(--color-bg))] p-4 text-center">
          <div
            class="mb-2 text-2xl font-bold text-[rgb(var(--color-text))]"
            title="Writings containing code blocks or inline code"
          >
            {maturityIndicators.filter((post) => post.hasCode).length}
          </div>
          <div class="text-sm text-[rgb(var(--color-text-muted))]">Writings with Code</div>
          <div class="mt-1 text-xs text-blue-500">💻 Technical Depth</div>
        </div>
        <div class="rounded-lg bg-[rgb(var(--color-bg))] p-4 text-center">
          <div
            class="mb-2 text-2xl font-bold text-[rgb(var(--color-text))]"
            title="Writings containing external links or URLs"
          >
            {maturityIndicators.filter((post) => post.hasLinks).length}
          </div>
          <div class="text-sm text-[rgb(var(--color-text-muted))]">Writings with Links</div>
          <div class="mt-1 text-xs text-green-500">🔗 Research Quality</div>
        </div>
        <div class="rounded-lg bg-[rgb(var(--color-bg))] p-4 text-center">
          <div
            class="mb-2 text-2xl font-bold text-[rgb(var(--color-text))]"
            title="Writings containing questions"
          >
            {maturityIndicators.filter((post) => post.hasQuestions).length}
          </div>
          <div class="text-sm text-[rgb(var(--color-text-muted))]">Writings with Questions</div>
          <div class="mt-1 text-xs text-purple-500">❓ Curiosity</div>
        </div>
        <div class="rounded-lg bg-[rgb(var(--color-bg))] p-4 text-center">
          <div
            class="mb-2 text-2xl font-bold text-[rgb(var(--color-text))]"
            title="Writings with more than 1000 words"
          >
            {maturityIndicators.filter((post) => post.wordCount > 1000).length}
          </div>
          <div class="text-sm text-[rgb(var(--color-text-muted))]">Long-form Writings</div>
          <div class="mt-1 text-xs text-yellow-500">📝 &gt;1k words</div>
        </div>
      </div>
    </div>

    {/* Intellectual Growth Formulas */}
    <div class="mb-6 md:mb-8 lg:mb-10">
      <h3
        class="mb-4 flex items-center gap-3 text-lg font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-xl"
      >
        <span class="text-2xl text-[rgb(var(--color-accent))]">📊</span>
        Metric definitions (Evolution page)
      </h3>
      <div class="space-y-6 md:space-y-8">
        <div class="grid grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2">
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-blue-500">🧠</span>
              Readability & language heuristics
            </h4>
            <div class="space-y-3 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Flesch reading ease per post:</strong>
                Uses the standard formula<br />
                <code class="mt-1 block rounded bg-[rgb(var(--color-bg-alt))] px-2 py-1 text-xs font-mono"
                  >206.835 − 1.015×(words÷sentences) − 84.6×(syllables÷words)</code
                >
                with <strong class="text-[rgb(var(--color-text))]">syllables ≈ vowel count trick</strong>,
                so it is <em>not</em> linguistically exact. Higher values mean “easier” on the scale, not smarter.
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Word-pattern composite:</strong> Counts of
                three hand-picked word lists (argument transitions, curiosity stems, reflective stems) plus
                <code class="rounded bg-[rgb(var(--color-bg-alt))] px-1 font-mono text-xs"
                  >⌊word_count ÷ 50⌋</code
                >-style term so long posts mechanically score higher even if content is thin.
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Maturity score:</strong> Checkbox score for
                Markdown features (code fences, links, blockquotes, question marks, cue phrases) plus points
                when &gt;1000 words or the word-pattern composite clears a low threshold—not editorial quality.
              </p>
              <p class="border-t border-[rgb(var(--color-border))]/40 pt-3 text-xs italic">
                Nothing here measures truth, originality, kindness, rigor cited from sources outside the file, or psychological traits.
              </p>
            </div>
          </div>
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-purple-500">📚</span>
              Knowledge Area Evolution
            </h4>
            <div class="space-y-3 text-[rgb(var(--color-text-muted))]">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Topic Diversity:</strong> Number of distinct
                knowledge areas
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Growth Trends:</strong> Growing/Declining/Stable
                topic areas
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Focus Concentration:</strong> Top topic
                percentage of total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Exploration Depth:</strong> Average posts
                per knowledge area
              </p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2">
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-green-500">🎓</span>
              Maturity Indicators
            </h4>
            <div class="space-y-3 text-[rgb(var(--color-text-muted))]">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Long-form Content:</strong> Posts >1000
                words / Total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Curiosity Level:</strong> Posts with questions
                / Total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Technical Integration:</strong> Code-containing
                posts / Total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Research Integration:</strong> Link-containing
                posts / Total posts
              </p>
            </div>
          </div>
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-orange-500">📈</span>
              Learning Trajectory
            </h4>
            <div class="space-y-3 text-[rgb(var(--color-text-muted))]">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Quarterly Growth:</strong> Post count and
                word count per quarter
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Topic Evolution:</strong> Category distribution
                over time periods
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Depth Progression:</strong> Average post
                length trend
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Complexity Progression:</strong> Technical
                content frequency trend
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Analysis Conclusion */}
    <div
      class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] p-4 md:p-6"
    >
      <h3 class="mb-4 text-base font-semibold text-[rgb(var(--color-text))] md:mb-6 md:text-lg">
        📈 Intellectual Growth Summary
      </h3>
      <div class="space-y-4">
        {/* Dynamic Insights */}
        <div class="space-y-2">
          {
            insights.map((insight) => (
              <div class={`flex items-center gap-2 ${insight.color}`}>
                <span class="text-sm">
                  {insight.type === 'positive'
                    ? '✅'
                    : insight.type === 'negative'
                      ? '❌'
                      : insight.type === 'warning'
                        ? '⚠️'
                        : 'ℹ️'}
                </span>
                <span class="text-sm" set:html={insight.text} />
              </div>
            ))
          }
        </div>

        {/* Summary */}
        <div class="pt-4">
          <p class="text-sm text-[rgb(var(--color-text-muted))]" set:html={summary} />
        </div>
      </div>
    </div>
  </BrainScienceLayout>
</BaseLayout>
