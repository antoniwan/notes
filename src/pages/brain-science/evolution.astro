---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BrainScienceLayout from '../../components/brain-science/BrainScienceLayout.astro';
import BrainScienceNarrativeSummary from '../../components/brain-science/BrainScienceNarrativeSummary.astro';
import TimeSeriesChart from '../../components/brain-science/TimeSeriesChart.astro';
import BarChart from '../../components/brain-science/BarChart.astro';
import { getBrainSciencePosts } from '../../utils/brainScience/data';
import { getTagWeight } from '../../data/tags';
import { endOfQuarter, eachQuarterOfInterval } from 'date-fns';
import { generateDynamicInsights, calculateObjectiveMetrics } from '../../utils/insightGenerator';
import { BRAIN_SCIENCE_PAGES } from '../../data/brainScience';

// Get all published posts
const posts = await getBrainSciencePosts();

// Sort posts by date
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Content evolution analysis
const contentEvolution = posts.map((post) => {
  const content = post.body || '';
  const wordCount = content.split(/\s+/).length;
  const paragraphCount = content.split('\n\n').length;
  const sentenceCount = content.split(/[.!?]+/).length - 1;
  const averageSentenceLength = sentenceCount > 0 ? Math.round(wordCount / sentenceCount) : 0;

  // Calculate complexity score
  const syllableCount = content
    .toLowerCase()
    .replace(/[^a-z]/g, '')
    .split('')
    .filter((char) => 'aeiou'.includes(char)).length;
  const fleschScore =
    sentenceCount > 0
      ? Math.round(
          206.835 - 1.015 * (wordCount / sentenceCount) - 84.6 * (syllableCount / wordCount),
        )
      : 0;

  // Calculate intellectual depth indicators
  const intellectualWords = [
    'because',
    'therefore',
    'however',
    'although',
    'nevertheless',
    'furthermore',
    'moreover',
    'consequently',
    'thus',
    'hence',
    'accordingly',
    'similarly',
    'conversely',
    'meanwhile',
    'subsequently',
    'previously',
    'initially',
    'ultimately',
    'fundamentally',
    'essentially',
  ];
  const intellectualWordCount = intellectualWords.reduce((count, word) => {
    const regex = new RegExp(`\\b${word}\\b`, 'gi');
    return count + (content.match(regex) || []).length;
  }, 0);

  // Calculate curiosity indicators
  const curiosityWords = [
    'wonder',
    'curious',
    'question',
    'explore',
    'discover',
    'investigate',
    'examine',
    'analyze',
    'study',
    'research',
    'learn',
    'understand',
    'figure out',
    'find out',
    'look into',
    'dive into',
    'explore',
    'uncover',
    'reveal',
    'unveil',
  ];
  const curiosityCount = curiosityWords.reduce((count, word) => {
    const regex = new RegExp(`\\b${word}\\b`, 'gi');
    return count + (content.match(regex) || []).length;
  }, 0);

  // Calculate wisdom indicators
  const wisdomWords = [
    'experience',
    'learned',
    'realized',
    'understood',
    'discovered',
    'found',
    'came to',
    'figured out',
    'worked out',
    'determined',
    'concluded',
    'decided',
    'chose',
    'opted',
    'selected',
    'preferred',
    'valued',
    'appreciated',
    'recognized',
    'acknowledged',
  ];
  const wisdomCount = wisdomWords.reduce((count, word) => {
    const regex = new RegExp(`\\b${word}\\b`, 'gi');
    return count + (content.match(regex) || []).length;
  }, 0);

  return {
    title: post.data.title,
    slug: post.id,
    date: post.data.pubDate,
    body: content,
    wordCount,
    paragraphCount,
    sentenceCount,
    averageSentenceLength,
    fleschScore,
    intellectualWordCount,
    curiosityCount,
    wisdomCount,
    readingTime: (() => {
      if (post.data.minutesRead && typeof post.data.minutesRead === 'string') {
        // Extract minutes from "X min read" format
        const match = post.data.minutesRead.match(/(\d+)/);
        return match ? parseInt(match[1]) : Math.ceil(wordCount / 200);
      }
      return Math.ceil(wordCount / 200);
    })(),
    tags: post.data.tags || [],
    categories: post.data.category || [],
    complexityScore: fleschScore + wordCount / 100 + paragraphCount * 2,
    intellectualDepth: intellectualWordCount + curiosityCount + wisdomCount + wordCount / 50,
  };
});

// Topic progression over time (by quarters)
const quarters = [];
const currentYear = new Date().getFullYear();
const startYear = sortedPosts[sortedPosts.length - 1]?.data.pubDate.getFullYear() || currentYear;

for (let year = startYear; year <= currentYear; year++) {
  for (let quarter = 1; quarter <= 4; quarter++) {
    const quarterStart = new Date(year, (quarter - 1) * 3, 1);
    const quarterEnd = new Date(year, quarter * 3, 0);

    const quarterPosts = posts.filter(
      (post) => post.data.pubDate >= quarterStart && post.data.pubDate <= quarterEnd,
    );

    if (quarterPosts.length > 0) {
      const quarterTags = quarterPosts.reduce(
        (acc, post) => {
          post.data.tags?.forEach((tag) => {
            acc[tag] = (acc[tag] || 0) + 1;
          });
          return acc;
        },
        {} as Record<string, number>,
      );

      const quarterCategories = quarterPosts.reduce(
        (acc, post) => {
          post.data.category?.forEach((cat) => {
            acc[cat] = (acc[cat] || 0) + 1;
          });
          return acc;
        },
        {} as Record<string, number>,
      );

      quarters.push({
        year,
        quarter,
        label: `Q${quarter} ${year}`,
        posts: quarterPosts.length,
        topTags: Object.entries(quarterTags)
          .sort(([, a], [, b]) => b - a)
          .slice(0, 5)
          .map(([tag, count]) => ({ tag, count, weight: getTagWeight(tag) })),
        topCategories: Object.entries(quarterCategories)
          .sort(([, a], [, b]) => b - a)
          .slice(0, 3)
          .map(([cat, count]) => ({ cat, count })),
        avgWordCount: Math.round(
          quarterPosts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0) /
            quarterPosts.length,
        ),
        avgComplexity: Math.round(
          quarterPosts.reduce((sum, post) => {
            const content = post.body || '';
            const wordCount = content.split(/\s+/).length;
            const sentenceCount = content.split(/[.!?]+/).length - 1;
            const syllableCount = content
              .toLowerCase()
              .replace(/[^a-z]/g, '')
              .split('')
              .filter((char) => 'aeiou'.includes(char)).length;
            const fleschScore =
              sentenceCount > 0
                ? Math.round(
                    206.835 -
                      1.015 * (wordCount / sentenceCount) -
                      84.6 * (syllableCount / wordCount),
                  )
                : 0;
            return sum + fleschScore;
          }, 0) / quarterPosts.length,
        ),
      });
    }
  }
}

// Writing style evolution
const styleEvolution = contentEvolution
  .sort((a, b) => a.date.valueOf() - b.date.valueOf())
  .map((post, index) => ({
    ...post,
    trendIndex: index,
    period:
      index < contentEvolution.length / 3
        ? 'Early'
        : index < (contentEvolution.length * 2) / 3
          ? 'Middle'
          : 'Recent',
  }));

// Complexity trends
const complexityTrends = styleEvolution.reduce(
  (acc, post) => {
    const period = post.period;
    if (!acc[period]) {
      acc[period] = [];
    }
    acc[period].push(post);
    return acc;
  },
  {} as Record<string, typeof styleEvolution>,
);

const periodStats = Object.entries(complexityTrends).map(([period, posts]) => ({
  period,
  avgWordCount: Math.round(posts.reduce((sum, post) => sum + post.wordCount, 0) / posts.length),
  avgComplexity: Math.round(posts.reduce((sum, post) => sum + post.fleschScore, 0) / posts.length),
  avgIntellectualDepth: Math.round(
    posts.reduce((sum, post) => sum + post.intellectualDepth, 0) / posts.length,
  ),
  avgCuriosityCount: Math.round(
    posts.reduce((sum, post) => sum + post.curiosityCount, 0) / posts.length,
  ),
  avgWisdomCount: Math.round(posts.reduce((sum, post) => sum + post.wisdomCount, 0) / posts.length),
  avgReadingTime: Math.round(posts.reduce((sum, post) => sum + post.readingTime, 0) / posts.length),
  postCount: posts.length,
}));

const maxPeriodFlesch =
  periodStats.length > 0 ? Math.max(...periodStats.map((p) => p.avgComplexity)) : 0;

const periodStatsOrdered = (['Early', 'Middle', 'Recent'] as const)
  .map((label) => periodStats.find((p) => p.period === label))
  .filter((p): p is (typeof periodStats)[number] => p != null);

// Most evolved topics (topics that have grown in frequency over time)
interface TopicGrowth {
  tag: string;
  earlyCount: number;
  recentCount: number;
  growth: number;
  growthRate: number;
}

const topicGrowth: Record<string, TopicGrowth> = {};
const earlyQuarters = quarters.slice(0, Math.floor(quarters.length / 3));
const recentQuarters = quarters.slice(-Math.floor(quarters.length / 3));

// Compare early vs recent topic frequency
const allTags = new Set<string>();
quarters.forEach((quarter) => quarter.topTags.forEach((tag) => allTags.add(tag.tag)));

allTags.forEach((tag) => {
  const earlyCount = earlyQuarters.reduce(
    (sum, quarter) => sum + (quarter.topTags.find((t) => t.tag === tag)?.count || 0),
    0,
  );
  const recentCount = recentQuarters.reduce(
    (sum, quarter) => sum + (quarter.topTags.find((t) => t.tag === tag)?.count || 0),
    0,
  );

  if (earlyCount > 0 || recentCount > 0) {
    topicGrowth[tag] = {
      tag,
      earlyCount,
      recentCount,
      growth: recentCount - earlyCount,
      growthRate:
        earlyCount > 0
          ? ((recentCount - earlyCount) / earlyCount) * 100
          : recentCount > 0
            ? 100
            : 0,
    };
  }
});

const growingTopics = Object.values(topicGrowth)
  .sort((a, b) => b.growthRate - a.growthRate)
  .slice(0, 10);

const decliningTopics = Object.values(topicGrowth)
  .sort((a, b) => a.growthRate - b.growthRate)
  .slice(0, 10);

// Writing maturity indicators
const maturityIndicators = contentEvolution.map((post) => {
  const content = post.body || '';
  const hasCode = /```[\s\S]*```/.test(content) || /`[^`]+`/.test(content);
  const hasLinks = /\[.*\]\(https?:\/\/.*\)/.test(content) || /https?:\/\/[^\s]+/.test(content);
  const hasImages = /!\[.*\]\(.*\)/.test(content);
  const hasQuotes = />\s+.+/.test(content);
  const hasQuestions = /\?/g.test(content);
  const hasExamples = /for example|such as|like|including|e\.g\.|i\.e\./gi.test(content);

  return {
    ...post,
    hasCode,
    hasLinks,
    hasImages,
    hasQuotes,
    hasQuestions,
    hasExamples,
    maturityScore:
      (hasCode ? 2 : 0) +
      (hasLinks ? 1 : 0) +
      (hasImages ? 1 : 0) +
      (hasQuotes ? 1 : 0) +
      (hasQuestions ? 1 : 0) +
      (hasExamples ? 1 : 0) +
      (post.wordCount > 1000 ? 2 : 0) +
      (post.intellectualDepth > 10 ? 2 : 0),
  };
});

const avgMaturityScore = Math.round(
  maturityIndicators.reduce((sum, post) => sum + post.maturityScore, 0) / maturityIndicators.length,
);

// Heuristic summaries (counts & formulas — not measures of IQ or “truth”)
const intellectualInsights = [
  {
    insight: 'Language-heuristic totals shifted between early and recent writing',
    evidence: `${periodStats[periodStats.length - 1]?.avgIntellectualDepth || 0} vs ${periodStats[0]?.avgIntellectualDepth || 0} avg composite (word-list hits + word count term)`,
    impact: 'High',
    reflection: 'Any change here can be length or vocabulary habits—not automatically “depth.”',
  },
  {
    insight: 'Curiosity word-list hits averaged per post shifted',
    evidence: `Recent slice: ~${periodStats[periodStats.length - 1]?.avgCuriosityCount || 0} matches per post (curated “wonder / explore / research …” stems in raw Markdown)`,
    impact: 'High',
    reflection: 'Frequency can reflect topic or habit—not intrinsically ‘more curious.’',
  },
  {
    insight: 'Reflective language stems averaged per post shifted',
    evidence: `Recent slice: ~${periodStats[periodStats.length - 1]?.avgWisdomCount || 0} matches per post (curated “learned / realized / chose …” stems)`,
    impact: 'Medium',
    reflection: 'These are rhetorical tics you can game; treat as texture, not virtue.',
  },
  {
    insight: 'Your knowledge areas are expanding',
    evidence: `${growingTopics.length} topics growing vs ${decliningTopics.length} declining`,
    impact: 'High',
    reflection: 'Which new areas of knowledge excite you most?',
  },
];

// Calculate objective metrics
const objectiveMetrics = calculateObjectiveMetrics(posts);

// Generate dynamic insights
const insightData = {
  totalPosts: posts.length,
  totalWords: posts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0),
  avgWordsPerPost: Math.round(
    posts.reduce((sum, post) => sum + (post.body || '').split(/\s+/).length, 0) / posts.length,
  ),
  topTags: Object.entries(
    posts.reduce(
      (acc, post) => {
        post.data.tags?.forEach((tag: string) => {
          acc[tag] = (acc[tag] || 0) + 1;
        });
        return acc;
      },
      {} as Record<string, number>,
    ),
  )
    .sort(([, a], [, b]) => b - a)
    .slice(0, 5)
    .map(([tag, count]) => ({ tag, count })),
  emotionalPosts: 0, // Not calculated for evolution
  growthPosts: 0, // Not calculated for evolution
  complexityTrend: (() => {
    const early = periodStats[0]?.avgComplexity ?? NaN;
    const recent = periodStats[periodStats.length - 1]?.avgComplexity ?? NaN;
    if (Number.isNaN(early) || Number.isNaN(recent) || periodStats.length < 2)
      return 'stable' as const;
    if (Math.abs(recent - early) < 3) return 'stable' as const;
    /* Flesch: higher score ≈ easier text */
    return recent > early ? ('increasing' as const) : ('decreasing' as const);
  })(),
  productivityTrend: 'stable' as const, // Not calculated for evolution
  knowledgeAreas: [],
  writingStreaks: [],
  drySpells: [],
  // Add objective metrics
  ...objectiveMetrics,
};

const { insights, summary } = generateDynamicInsights(insightData, 'evolution');

// Prepare time series data for complexity evolution
const sortedContentEvolution = contentEvolution.sort((a, b) => a.date.valueOf() - b.date.valueOf());
const firstDate = sortedContentEvolution[0]?.date || new Date();
const lastDate = sortedContentEvolution[sortedContentEvolution.length - 1]?.date || new Date();
const complexityQuarters = eachQuarterOfInterval({ start: firstDate, end: lastDate });

const complexityTimeSeries = complexityQuarters
  .map((quarterStart) => {
    const quarterEnd = endOfQuarter(quarterStart);
    const quarterLabel = `Q${Math.floor(quarterStart.getMonth() / 3) + 1} ${quarterStart.getFullYear()}`;

    const quarterPosts = sortedContentEvolution.filter(
      (post) => post.date >= quarterStart && post.date <= quarterEnd,
    );

    const avgComplexity =
      quarterPosts.length > 0
        ? quarterPosts.reduce((sum, post) => sum + post.fleschScore, 0) / quarterPosts.length
        : 0;

    const avgIntellectualDepth =
      quarterPosts.length > 0
        ? quarterPosts.reduce((sum, post) => sum + post.intellectualDepth, 0) / quarterPosts.length
        : 0;

    return {
      label: quarterLabel,
      complexity: Math.round(avgComplexity * 100) / 100,
      intellectualDepth: Math.round(avgIntellectualDepth * 100) / 100,
    };
  })
  .filter((q) => q.complexity > 0 || q.intellectualDepth > 0);

// Prepare bar chart for period comparison
const periodComparisonChart = {
  labels: periodStatsOrdered.map((p) => p.period),
  datasets: [
    {
      label: 'Avg Word Count',
      data: periodStatsOrdered.map((p) => (isNaN(p.avgWordCount) ? 0 : p.avgWordCount)),
      backgroundColor: 'rgba(59, 130, 246, 0.6)',
      borderColor: 'rgb(59, 130, 246)',
    },
    {
      label: 'Avg Flesch reading ease',
      data: periodStatsOrdered.map((p) => (isNaN(p.avgComplexity) ? 0 : p.avgComplexity)),
      backgroundColor: 'rgba(147, 51, 234, 0.6)',
      borderColor: 'rgb(147, 51, 234)',
    },
    {
      label: 'Avg word-pattern composite',
      data: periodStatsOrdered.map((p) =>
        isNaN(p.avgIntellectualDepth) ? 0 : p.avgIntellectualDepth,
      ),
      backgroundColor: 'rgba(34, 197, 94, 0.6)',
      borderColor: 'rgb(34, 197, 94)',
    },
  ],
};

// Get page info
const pageInfo = BRAIN_SCIENCE_PAGES.find((p) => p.id === 'evolution');
---

<BaseLayout
  title="Intellectual Growth Analytics - Brain Science"
  description="Readability (Flesch) and word-pattern heuristics over time from post bodies—experimental signals, not IQ or quality scores."
  path="/brain-science/evolution"
  structuredDataType="website"
>
  <BrainScienceLayout
    currentPage="/brain-science/evolution"
    title={pageInfo?.title || 'Intellectual Growth Analytics'}
    description="Readability formulas and hand-picked word-pattern tallies over time—signals about language, not IQ or depth."
  >
    {/* Snapshot row — notebook-style, no cards */}
    <div
      class="mb-6 flex flex-wrap gap-x-10 gap-y-5 border-b border-[rgb(var(--color-border))]/50 pb-6 md:mb-8 md:gap-x-14 md:pb-8"
    >
      <div title="Quarters with published posts (calendar quarters)">
        <div class="text-2xl font-semibold tabular-nums text-[rgb(var(--color-text))] md:text-3xl">
          {quarters.length}
        </div>
        <div class="text-xs text-body-muted">Quarters</div>
      </div>
      <div title="Mean maturity checklist score (format features in body — heuristic)">
        <div class="text-2xl font-semibold tabular-nums text-[rgb(var(--color-text))] md:text-3xl">
          {avgMaturityScore}
        </div>
        <div class="text-xs text-body-muted">Avg maturity (format)</div>
      </div>
      <div title="Tag categories with positive early→recent growth">
        <div
          class="text-2xl font-semibold tabular-nums text-green-600 dark:text-green-400 md:text-3xl"
        >
          {growingTopics.length}
        </div>
        <div class="text-xs text-body-muted">Tags rising</div>
      </div>
      <div title="Tag categories with negative early→recent growth">
        <div class="text-2xl font-semibold tabular-nums text-red-600 dark:text-red-400 md:text-3xl">
          {decliningTopics.length}
        </div>
        <div class="text-xs text-body-muted">Tags falling</div>
      </div>
    </div>

    <nav
      class="mb-8 border-b border-dashed border-[rgb(var(--color-border))]/50 pb-4 md:mb-10"
      aria-label="On this page"
    >
      <div
        class="mb-2 text-[0.65rem] font-semibold uppercase tracking-wider text-body-muted"
      >
        Jump to
      </div>
      <ul class="m-0 flex list-none flex-wrap gap-x-4 gap-y-2 p-0 text-sm">
        <li class="m-0 p-0">
          <a
            href="#readability-chart"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Readability chart</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#by-period"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >By period</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#topics"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Tags</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#quarters"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Quarter table</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#format-mix"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Format checks</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#definitions"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Definitions</a
          >
        </li>
        <li class="m-0 p-0">
          <a
            href="#summary"
            class="text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/30 underline-offset-4 hover:decoration-[rgb(var(--color-accent))]"
            >Narrative summary</a
          >
        </li>
      </ul>
    </nav>

    {
      /* Readability + heuristic (line colors match legend — explicit colors preserved by TimeSeriesChart) */
    }
    {
      complexityTimeSeries.length > 0 && (
        <section
          id="readability-chart"
          class="mb-10 scroll-mt-28 md:mb-12"
          aria-labelledby="readability-heading"
        >
          <h2
            id="readability-heading"
            class="mb-2 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
          >
            Readability &amp; word-pattern index
          </h2>
          <p class="mb-4 max-w-3xl text-sm leading-relaxed text-body-muted">
            Quarterly means from post bodies only. Drift in wording or length—not a score of how
            smart posts are.
          </p>

          <details class="mb-5" open>
            <summary class="cursor-pointer list-none text-sm font-medium text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/25 underline-offset-4 marker:content-none [&::-webkit-details-marker]:hidden">
              How to read the two lines
            </summary>
            <div class="mt-3 space-y-3 border-l-2 border-[rgb(var(--color-border))]/60 pl-4 text-sm leading-relaxed text-body-muted">
              <p class="m-0 flex flex-wrap items-start gap-2">
                <span
                  class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-[rgb(147,51,234)]"
                  aria-hidden="true"
                />
                <span>
                  <strong class="text-[rgb(var(--color-text))]">
                    Flesch reading ease (purple).
                  </strong>{' '}
                  Higher = simpler sentences/vocabulary <em>by formula</em>. Syllables are
                  approximated (vowel heuristic). Typical blog-ish scores often land ~30–70.
                </span>
              </p>
              <p class="m-0 flex flex-wrap items-start gap-2">
                <span
                  class="mt-1.5 h-2.5 w-2.5 shrink-0 rounded-full bg-[rgb(34,197,94)]"
                  aria-hidden="true"
                />
                <span>
                  <strong class="text-[rgb(var(--color-text))]">
                    Word-pattern composite (green).
                  </strong>{' '}
                  Toy counter: discourse / curiosity / reflection word lists + a length term (
                  <code class="rounded-sm bg-[rgb(var(--color-bg-alt))] px-1 py-0.5 font-mono text-xs">
                    words÷50
                  </code>
                  ). Long posts score higher mechanically.
                </span>
              </p>
              <p class="m-0 text-xs md:text-sm">
                <strong class="text-[rgb(var(--color-text))]">Axis caveat:</strong> both series
                share one scale—compare directionally, not as equal units.
              </p>
            </div>
          </details>

          <div class="-mx-1 md:mx-0">
            <TimeSeriesChart
              id="complexity-evolution"
              labels={complexityTimeSeries.map((q) => q.label)}
              datasets={[
                {
                  label: 'Flesch reading ease (avg)',
                  data: complexityTimeSeries.map((q) => (isNaN(q.complexity) ? 0 : q.complexity)),
                  borderColor: 'rgb(147, 51, 234)',
                  backgroundColor: 'rgba(147, 51, 234, 0.12)',
                },
                {
                  label: 'Word-pattern composite (avg)',
                  data: complexityTimeSeries.map((q) =>
                    isNaN(q.intellectualDepth) ? 0 : q.intellectualDepth,
                  ),
                  borderColor: 'rgb(34, 197, 94)',
                  backgroundColor: 'rgba(34, 197, 94, 0.12)',
                },
              ]}
              title=""
              yAxisLabel="Mixed units — see legend"
            />
          </div>
        </section>
      )
    }

    <section id="by-period" class="mb-10 scroll-mt-28 md:mb-12" aria-labelledby="by-period-heading">
      <h2
        id="by-period-heading"
        class="mb-2 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
      >
        By period: Early, Middle, Recent
      </h2>
      <p class="mb-6 max-w-3xl text-sm leading-relaxed text-body-muted">
        The archive is split into <strong class="font-medium text-[rgb(var(--color-text))]"
          >thirds by publication order</strong
        >. Bar chart and tables use <strong class="font-medium text-[rgb(var(--color-text))]"
          >mixed units</strong
        >—look for direction, not precise ratios between series.
      </p>

      {
        periodComparisonChart.labels.length > 0 && (
          <div class="-mx-1 mb-10 md:mx-0">
            <BarChart
              id="period-comparison-chart"
              labels={periodComparisonChart.labels}
              datasets={periodComparisonChart.datasets}
              title=""
              yAxisLabel="Mixed units — see intro"
            />
          </div>
        )
      }

      <details class="mb-10">
        <summary
          class="cursor-pointer list-none text-sm font-medium text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/25 underline-offset-4 marker:content-none [&::-webkit-details-marker]:hidden"
        >
          Signal notes (informal, not significance tests)
        </summary>
        <p
          class="mt-3 max-w-3xl text-xs leading-relaxed text-body-muted md:text-sm"
        >
          Emphasis tags are for this page only. Counts come from post bodies.
        </p>
        <div class="mt-4 divide-y divide-[rgb(var(--color-border))]/40">
          {
            intellectualInsights.map((insight, index) => (
              <article class="py-5 first:pt-2">
                <div class="mb-2 flex flex-wrap items-baseline gap-x-2 gap-y-1">
                  <span class="font-mono text-xs text-body-muted">
                    {index + 1}.
                  </span>
                  <span
                    class={`text-[0.65rem] font-medium uppercase tracking-wide ${
                      insight.impact === 'High'
                        ? 'text-green-600 dark:text-green-400'
                        : insight.impact === 'Medium'
                          ? 'text-amber-600 dark:text-amber-400'
                          : 'text-blue-600 dark:text-blue-400'
                    }`}
                  >
                    {insight.impact}
                  </span>
                </div>
                <p class="mb-2 text-sm font-medium text-[rgb(var(--color-text))]">
                  {insight.insight}
                </p>
                <p class="mb-0 text-xs leading-relaxed text-body-muted md:text-sm">
                  {insight.evidence}
                </p>
                <p class="mb-0 mt-2 text-xs italic text-body-muted">
                  {insight.reflection}
                </p>
              </article>
            ))
          }
        </div>
      </details>

      <h3
        class="mb-1 text-sm font-semibold uppercase tracking-wide text-body-muted"
      >
        Per-period means
      </h3>
      <p
        class="mb-3 max-w-3xl text-xs leading-relaxed text-body-muted md:text-sm"
      >
        One row per third of the archive. Flesch ↑ ≈ simpler wording (approx. syllables).
        Word-pattern Σ = toy composite from word lists + length term.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full min-w-128 border-collapse text-left text-sm">
          <thead>
            <tr
              class="border-b-2 border-[rgb(var(--color-border))] text-[0.65rem] font-semibold uppercase tracking-wider text-body-muted"
            >
              <th scope="col" class="py-2 pr-4 font-medium">Period</th>
              <th scope="col" class="py-2 pr-4 text-right font-medium tabular-nums">Posts</th>
              <th scope="col" class="py-2 pr-4 text-right font-medium tabular-nums">Avg words</th>
              <th
                scope="col"
                class="py-2 pr-4 text-right font-medium tabular-nums"
                title="Higher ≈ simpler (formula)"
              >
                Flesch
              </th>
              <th scope="col" class="py-2 pr-4 text-right font-medium tabular-nums">W.-pattern Σ</th
              >
              <th scope="col" class="py-2 pr-4 text-right font-medium tabular-nums">Curiosity</th>
              <th scope="col" class="py-2 text-right font-medium tabular-nums">Reflective</th>
            </tr>
          </thead>
          <tbody>
            {
              periodStatsOrdered.map((period) => (
                <tr class="border-b border-[rgb(var(--color-border))]/35 last:border-0">
                  <th
                    scope="row"
                    class="py-2.5 pr-4 font-medium capitalize text-[rgb(var(--color-text))]"
                  >
                    {period.period}
                  </th>
                  <td class="py-2.5 pr-4 text-right tabular-nums text-[rgb(var(--color-text))]">
                    {period.postCount}
                  </td>
                  <td class="py-2.5 pr-4 text-right tabular-nums text-[rgb(var(--color-text))]">
                    {period.avgWordCount}
                  </td>
                  <td
                    class={`py-2.5 pr-4 text-right tabular-nums ${
                      maxPeriodFlesch > 0 && period.avgComplexity >= maxPeriodFlesch * 0.8
                        ? 'text-green-600 dark:text-green-400'
                        : maxPeriodFlesch > 0 && period.avgComplexity >= maxPeriodFlesch * 0.5
                          ? 'text-blue-600 dark:text-blue-400'
                          : maxPeriodFlesch > 0 && period.avgComplexity >= maxPeriodFlesch * 0.2
                            ? 'text-amber-600 dark:text-amber-400'
                            : maxPeriodFlesch > 0
                              ? 'text-red-600 dark:text-red-400'
                              : 'text-[rgb(var(--color-text))]'
                    }`}
                    title="Avg Flesch reading ease — higher tends to mean simpler wording"
                  >
                    {period.avgComplexity}
                  </td>
                  <td class="py-2.5 pr-4 text-right tabular-nums text-[rgb(var(--color-text))]">
                    {period.avgIntellectualDepth}
                  </td>
                  <td class="py-2.5 pr-4 text-right tabular-nums text-[rgb(var(--color-text))]">
                    {period.avgCuriosityCount}
                  </td>
                  <td class="py-2.5 text-right tabular-nums text-[rgb(var(--color-text))]">
                    {period.avgWisdomCount}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {/* Topic Growth vs Decline Analysis */}
    <section
      id="topics"
      class="mb-10 grid scroll-mt-28 grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2"
      aria-labelledby="topics-growing-heading"
    >
      <div>
        <h3
          id="topics-growing-heading"
          class="mb-2 text-base font-semibold text-[rgb(var(--color-text))] md:text-lg"
        >
          Tags rising (early → recent)
        </h3>
        <p class="mb-4 text-xs text-body-muted">
          Positive growth rate:
          <code class="rounded-sm bg-[rgb(var(--color-bg-alt))] px-1 font-mono text-[0.65rem]">
            ((recent − early) ÷ early) × 100</code
          >.
        </p>
        <div class="divide-y divide-[rgb(var(--color-border))]/40">
          {
            growingTopics.map((topic, index) => (
              <div class="flex items-baseline justify-between gap-4 py-2.5 first:pt-0">
                <div class="min-w-0">
                  <span class="mr-2 font-mono text-xs text-body-muted">
                    {index + 1}.
                  </span>
                  <span class="text-sm font-medium text-[rgb(var(--color-text))]">{topic.tag}</span>
                  <span class="mt-0.5 block text-xs text-body-muted sm:mt-0 sm:inline sm:before:content-['_·_']">
                    {topic.earlyCount} → {topic.recentCount}
                  </span>
                </div>
                <div
                  class="shrink-0 text-sm font-medium tabular-nums text-green-600 dark:text-green-400"
                  title={`Growth rate: ${Math.round(topic.growthRate)}% increase from early to recent`}
                >
                  +{Math.round(topic.growthRate)}%
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div>
        <h3
          id="topics-declining-heading"
          class="mb-2 text-base font-semibold text-[rgb(var(--color-text))] md:text-lg"
        >
          Tags falling (early → recent)
        </h3>
        <p class="mb-4 text-xs text-body-muted">
          Negative growth rate:
          <code class="rounded-sm bg-[rgb(var(--color-bg-alt))] px-1 font-mono text-[0.65rem]">
            ((recent − early) ÷ early) × 100</code
          >.
        </p>
        <div class="divide-y divide-[rgb(var(--color-border))]/40">
          {
            decliningTopics.map((topic, index) => (
              <div class="flex items-baseline justify-between gap-4 py-2.5 first:pt-0">
                <div class="min-w-0">
                  <span class="mr-2 font-mono text-xs text-body-muted">
                    {index + 1}.
                  </span>
                  <span class="text-sm font-medium text-[rgb(var(--color-text))]">{topic.tag}</span>
                  <span class="mt-0.5 block text-xs text-body-muted sm:mt-0 sm:inline sm:before:content-['_·_']">
                    {topic.earlyCount} → {topic.recentCount}
                  </span>
                </div>
                <div
                  class="shrink-0 text-sm font-medium tabular-nums text-red-600 dark:text-red-400"
                  title={`Decline rate: ${Math.round(topic.growthRate)}%`}
                >
                  {Math.round(topic.growthRate)}%
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Recent quarters — compact scan */}
    <section id="quarters" class="mb-10 scroll-mt-28 md:mb-12" aria-labelledby="quarters-heading">
      <h2
        id="quarters-heading"
        class="mb-2 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
      >
        Last eight quarters
      </h2>
      <p
        class="mb-4 max-w-3xl text-xs leading-relaxed text-body-muted md:text-sm"
      >
        Newest-first rows. Body text only for Flesch; syllables are approximated (
        <span class="whitespace-nowrap">higher ≈ simpler</span>).
      </p>
      <div class="overflow-x-auto">
        <table
          class="w-full min-w-144 border-collapse border-b border-t border-[rgb(var(--color-border))] text-left text-sm"
        >
          <thead>
            <tr
              class="border-b border-[rgb(var(--color-border))] text-[0.65rem] font-semibold uppercase tracking-wider text-body-muted"
            >
              <th scope="col" class="whitespace-nowrap px-3 py-2.5">Quarter</th>
              <th scope="col" class="px-3 py-2.5 text-right tabular-nums">Posts</th>
              <th scope="col" class="px-3 py-2.5 text-right tabular-nums">Avg words</th>
              <th scope="col" class="px-3 py-2.5 text-right tabular-nums">Flesch ~</th>
              <th scope="col" class="min-w-40 px-3 py-2.5">Top tags</th>
              <th scope="col" class="min-w-32 px-3 py-2.5">Categories</th>
            </tr>
          </thead>
          <tbody>
            {
              quarters
                .slice(-8)
                .reverse()
                .map((quarter) => (
                  <tr class="border-b border-[rgb(var(--color-border))]/50 last:border-0">
                    <th
                      scope="row"
                      class="whitespace-nowrap px-3 py-2.5 font-medium text-[rgb(var(--color-text))]"
                    >
                      {quarter.label}
                    </th>
                    <td class="px-3 py-2.5 text-right tabular-nums text-[rgb(var(--color-text))]">
                      {quarter.posts}
                    </td>
                    <td class="px-3 py-2.5 text-right tabular-nums text-[rgb(var(--color-text))]">
                      {quarter.avgWordCount}
                    </td>
                    <td
                      class="px-3 py-2.5 text-right tabular-nums text-[rgb(var(--color-text))]"
                      title="Average Flesch reading ease — higher tends to mean simpler wording (approximate syllables)."
                    >
                      {quarter.avgComplexity}
                    </td>
                    <td class="px-3 py-2.5 align-top text-xs leading-snug text-body-muted">
                      {quarter.topTags
                        .slice(0, 4)
                        .map((t) => `${t.tag} (${t.count})`)
                        .join(' · ')}
                    </td>
                    <td class="px-3 py-2.5 align-top text-xs leading-snug text-body-muted">
                      {quarter.topCategories
                        .slice(0, 3)
                        .map((c) => `${c.cat} (${c.count})`)
                        .join(' · ')}
                    </td>
                  </tr>
                ))
            }
          </tbody>
        </table>
      </div>
    </section>

    {/* Writing Maturity */}
    <section
      id="format-mix"
      class="mb-10 scroll-mt-28 md:mb-12"
      aria-labelledby="format-mix-heading"
    >
      <h2
        id="format-mix-heading"
        class="mb-2 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
      >
        Format &amp; structure checks
      </h2>
      <p
        class="mb-4 max-w-3xl text-xs leading-relaxed text-body-muted md:text-sm"
      >
        Heuristic checkbox on the Markdown body (not editorial quality). Expression:
      </p>
      <pre
        class="mb-5 max-w-3xl overflow-x-auto border-l-2 border-[rgb(var(--color-border))]/70 pl-3 font-mono text-[0.7rem] leading-relaxed text-body-muted">(code fences / inline code ? 2 : 0) + (URLs ? 1 : 0) + (images ? 1 : 0) + (blockquotes ? 1 : 0)
+ (? in body ? 1 : 0) + (e.g./such as cues ? 1 : 0) + (words &gt; 1000 ? 2 : 0)
+ (word-pattern composite &gt; 10 ? 2 : 0)</pre>
      <table class="w-full max-w-md border-collapse text-sm tabular-nums">
        <tbody>
          <tr class="border-b border-[rgb(var(--color-border))]/35">
            <td
              class="py-2 pr-4 text-body-muted"
              title="Code fences or inline code"
            >
              Posts with code
            </td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]">
              {maturityIndicators.filter((post) => post.hasCode).length}
            </td>
          </tr>
          <tr class="border-b border-[rgb(var(--color-border))]/35">
            <td class="py-2 pr-4 text-body-muted" title="External URLs">
              Posts with links
            </td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]">
              {maturityIndicators.filter((post) => post.hasLinks).length}
            </td>
          </tr>
          <tr class="border-b border-[rgb(var(--color-border))]/35">
            <td
              class="py-2 pr-4 text-body-muted"
              title="Question marks in body"
            >
              Posts with questions
            </td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]">
              {maturityIndicators.filter((post) => post.hasQuestions).length}
            </td>
          </tr>
          <tr>
            <td class="py-2 pr-4 text-body-muted" title="Word count > 1000">
              Long posts (&gt;1k words)
            </td>
            <td class="py-2 text-right font-medium text-[rgb(var(--color-text))]">
              {maturityIndicators.filter((post) => post.wordCount > 1000).length}
            </td>
          </tr>
        </tbody>
      </table>
    </section>

    {/* Metric definitions — collapsible */}
    <details
      id="definitions"
      class="mb-10 scroll-mt-28 border-t border-[rgb(var(--color-border))] pt-8 md:mb-12"
      open
    >
      <summary
        class="cursor-pointer list-none text-lg font-semibold text-[rgb(var(--color-text))] marker:content-none md:text-xl [&::-webkit-details-marker]:hidden"
      >
        Definitions &amp; formulas
      </summary>
      <div class="mt-6 space-y-8 md:space-y-10">
        <div class="grid grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2">
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-blue-500">🧠</span>
              Readability & language heuristics
            </h4>
            <div class="space-y-3 text-sm leading-relaxed text-body-muted">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Flesch reading ease per post:</strong>
                Uses the standard formula<br />
                <code
                  class="mt-1 block rounded-sm bg-[rgb(var(--color-bg-alt))] px-2 py-1 font-mono text-xs"
                  >206.835 − 1.015×(words÷sentences) − 84.6×(syllables÷words)</code
                >
                with <strong class="text-[rgb(var(--color-text))]"
                  >syllables ≈ vowel count trick</strong
                >, so it is <em>not</em> linguistically exact. Higher values mean “easier” on the scale,
                not smarter.
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Word-pattern composite:</strong> Counts
                of three hand-picked word lists (argument transitions, curiosity stems, reflective stems)
                plus
                <code class="rounded-sm bg-[rgb(var(--color-bg-alt))] px-1 font-mono text-xs"
                  >⌊word_count ÷ 50⌋</code
                >-style term so long posts mechanically score higher even if content is thin.
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Maturity score:</strong> Checkbox score
                for Markdown features (code fences, links, blockquotes, question marks, cue phrases) plus
                points when &gt;1000 words or the word-pattern composite clears a low threshold—not editorial
                quality.
              </p>
              <p class="border-t border-[rgb(var(--color-border))]/40 pt-3 text-xs italic">
                Nothing here measures truth, originality, kindness, rigor cited from sources outside
                the file, or psychological traits.
              </p>
            </div>
          </div>
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-purple-500">📚</span>
              Knowledge Area Evolution
            </h4>
            <div class="space-y-3 text-body-muted">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Topic Diversity:</strong> Number of distinct
                knowledge areas
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Growth Trends:</strong> Growing/Declining/Stable
                topic areas
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Focus Concentration:</strong> Top topic
                percentage of total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Exploration Depth:</strong> Average posts
                per knowledge area
              </p>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 md:gap-8 lg:grid-cols-2">
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-green-500">🎓</span>
              Maturity Indicators
            </h4>
            <div class="space-y-3 text-body-muted">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Long-form Content:</strong> Posts >1000
                words / Total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Curiosity Level:</strong> Posts with questions
                / Total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Technical Integration:</strong> Code-containing
                posts / Total posts
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Research Integration:</strong> Link-containing
                posts / Total posts
              </p>
            </div>
          </div>
          <div>
            <h4
              class="mb-4 flex items-center gap-2 text-lg font-semibold text-[rgb(var(--color-text))]"
            >
              <span class="text-orange-500">📈</span>
              Learning Trajectory
            </h4>
            <div class="space-y-3 text-body-muted">
              <p>
                <strong class="text-[rgb(var(--color-text))]">Quarterly Growth:</strong> Post count and
                word count per quarter
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Topic Evolution:</strong> Category distribution
                over time periods
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Depth Progression:</strong> Average post
                length trend
              </p>
              <p>
                <strong class="text-[rgb(var(--color-text))]">Complexity Progression:</strong> Technical
                content frequency trend
              </p>
            </div>
          </div>
        </div>
      </div>
    </details>

    <BrainScienceNarrativeSummary insights={insights} summary={summary} />
  </BrainScienceLayout>
</BaseLayout>
