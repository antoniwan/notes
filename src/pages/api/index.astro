---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import PageHeader from '../../components/PageHeader.astro';
import { SITE_TITLE } from '../../consts';
---

<BaseLayout
  title={`Public API - ${SITE_TITLE}`}
  description="JSON quotes endpoint: Stoic excerpts, other philosophy, and lines from posts on this site."
  path="/api"
>
  <Container>
    <Container maxWidth="container" padding="none">
      <PageHeader
        title="Public API"
        description="One endpoint today: random quotes for margins, 404 pages, and experiments. Responses include optional links back to notes when the line is from this site."
      />

      <div
        class="mb-8 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-alt))] p-6"
      >
        <div class="mb-4 flex flex-wrap items-start justify-between gap-4">
          <h2 class="text-xl font-semibold text-[rgb(var(--color-text))]">Quotes</h2>
          <a
            href="https://github.com/antoniwan/notes/blob/main/docs/quotes-api.md"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-1 text-sm text-blue-500 transition-colors hover:text-blue-600"
          >
            Full reference (GitHub)
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              ></path>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          <div class="space-y-4">
            <div>
              <h3 class="mb-2 font-medium text-[rgb(var(--color-text))]">Endpoint</h3>
              <code class="rounded-sm bg-[rgb(var(--color-bg))] px-3 py-2 font-mono text-sm"
                >GET /api/quotes</code
              >
              <p class="text-body-muted mt-2 text-sm leading-relaxed">
                Returns one random quote. The pool mixes classical Stoic lines, a few other
                philosophers and writers, and short pull quotes from essays published here. Each
                response includes a <code class="text-xs">kind</code> field (<code class="text-xs"
                  >stoic</code
                >, <code class="text-xs">philosophical</code>, or <code class="text-xs">site</code>)
                and <code class="text-xs">sourceUrl</code> when the line links to a post (<code
                  class="text-xs">/p/…/</code
                >).
              </p>
            </div>

            <div>
              <h3 class="mb-2 font-medium text-[rgb(var(--color-text))]">Optional query</h3>
              <code
                class="rounded-sm bg-[rgb(var(--color-bg))] px-3 py-2 font-mono text-sm break-all"
                >?kind=stoic</code
              >
              <span class="text-body-muted mx-2 text-sm">or</span>
              <code class="rounded-sm bg-[rgb(var(--color-bg))] px-3 py-2 font-mono text-sm"
                >philosophical</code
              >
              <span class="text-body-muted mx-2 text-sm">or</span>
              <code class="rounded-sm bg-[rgb(var(--color-bg))] px-3 py-2 font-mono text-sm"
                >site</code
              >
              <p class="text-body-muted mt-2 text-sm leading-relaxed">
                Limits the draw to that bucket. If something is mis-typed, you still get a random
                quote from the full list (no hard error).
              </p>
            </div>
          </div>

          <div>
            <h3 class="mb-2 font-medium text-[rgb(var(--color-text))]">Sample JSON</h3>
            <pre
              class="max-h-[min(420px,55vh)] overflow-auto rounded-sm border border-[rgb(var(--color-border))]/30 bg-[rgb(var(--color-bg))] p-4 text-xs leading-relaxed md:text-sm"><code>{`{
  "quote": {
    "id": 31,
    "kind": "site",
    "sourceUrl": "/p/intelligence-burns/",
    "postId": "intelligence-burns",
    "text": "People say they love intelligent people…",
    "author": "Antonio Rodriguez Martinez",
    "work": "Intelligence Burns",
    "book": null,
    "themes": ["intelligence", "relationships"],
    "category": "author_voice",
    "difficulty": "beginner",
    "length": "short",
    "popularity": "high",
    "context": "…",
    "modernRelevance": "…"
  },
  "metadata": {
    "totalQuotes": 42,
    "version": "2.0",
    "lastUpdated": "2026-05-08",
    "description": "Random quote: …",
    "countsByKind": {
      "stoic": 30,
      "philosophical": 6,
      "site": 6
    }
  }
}`}</code></pre>
          </div>
        </div>
      </div>

      <div
        class="mb-8 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-alt))] p-6"
      >
        <h2 class="mb-4 text-xl font-semibold text-[rgb(var(--color-text))]">Try it</h2>
        <div class="mb-4 flex flex-wrap gap-3" role="toolbar" aria-label="Quote tester">
          <button
            type="button"
            id="testApiAny"
            data-filter=""
            aria-pressed="false"
            class="api-quote-btn rounded-lg bg-blue-500 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-blue-600 aria-pressed:ring-2 aria-pressed:ring-blue-300"
          >
            Random (any)
          </button>
          <button
            type="button"
            id="testApiStoic"
            data-filter="stoic"
            aria-pressed="false"
            class="api-quote-btn rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-5 py-2.5 text-sm font-medium text-[rgb(var(--color-text))] transition-colors hover:bg-[rgb(var(--color-bg-secondary))] aria-pressed:border-blue-500 aria-pressed:ring-2 aria-pressed:ring-blue-500/30"
          >
            Stoic only
          </button>
          <button
            type="button"
            id="testApiPhil"
            data-filter="philosophical"
            aria-pressed="false"
            class="api-quote-btn rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-5 py-2.5 text-sm font-medium text-[rgb(var(--color-text))] transition-colors hover:bg-[rgb(var(--color-bg-secondary))] aria-pressed:border-blue-500 aria-pressed:ring-2 aria-pressed:ring-blue-500/30"
          >
            Philosophy
          </button>
          <button
            type="button"
            id="testApiSite"
            data-filter="site"
            aria-pressed="false"
            class="api-quote-btn rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-5 py-2.5 text-sm font-medium text-[rgb(var(--color-text))] transition-colors hover:bg-[rgb(var(--color-bg-secondary))] aria-pressed:border-blue-500 aria-pressed:ring-2 aria-pressed:ring-blue-500/30"
          >
            From this site
          </button>
        </div>
        <div
          id="apiResult"
          class="min-h-[180px] rounded-sm border border-[rgb(var(--color-border))]/30 bg-[rgb(var(--color-bg))] p-4"
        >
          <p class="text-body-muted text-sm">Choose a button to fetch a quote.</p>
        </div>
      </div>

      <div
        class="rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-alt))] p-6"
      >
        <h2 class="mb-4 text-xl font-semibold text-[rgb(var(--color-text))]">Code snippets</h2>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
          <div>
            <h3 class="mb-2 font-medium text-[rgb(var(--color-text))]">fetch</h3>
            <pre
              class="overflow-x-auto rounded-sm border border-[rgb(var(--color-border))]/30 bg-[rgb(var(--color-bg))] p-4 text-xs md:text-sm"><code>{`const res = await fetch('/api/quotes');
const { quote, metadata } = await res.json();
// quote.kind — 'stoic' | 'philosophical' | 'site'
// quote.sourceUrl — '/p/slug/' or null`}</code></pre>
          </div>
          <div>
            <h3 class="mb-2 font-medium text-[rgb(var(--color-text))]">Filtered</h3>
            <pre
              class="overflow-x-auto rounded-sm border border-[rgb(var(--color-border))]/30 bg-[rgb(var(--color-bg))] p-4 text-xs md:text-sm"><code>{`const res = await fetch(
  '/api/quotes?kind=site'
);`}</code></pre>
          </div>
        </div>
      </div>
    </Container>
  </Container>
</BaseLayout>

<script>
  const BTN_IDS = ['testApiAny', 'testApiStoic', 'testApiPhil', 'testApiSite'] as const;

  function getResultPanel() {
    return document.getElementById('apiResult');
  }

  function setBusy(busy: boolean) {
    for (const id of BTN_IDS) {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (btn) btn.disabled = busy;
    }
  }

  function setActiveFilter(kind: '' | 'stoic' | 'philosophical' | 'site') {
    for (const id of BTN_IDS) {
      const btn = document.getElementById(id) as HTMLButtonElement | null;
      if (!btn) continue;
      const v = btn.getAttribute('data-filter') ?? '';
      const pressed = kind === '' ? v === '' : v === kind;
      btn.setAttribute('aria-pressed', pressed ? 'true' : 'false');
    }
  }

  async function fetchQuote(kind?: '' | 'stoic' | 'philosophical' | 'site') {
    const fk = kind ?? '';
    const resultDiv = getResultPanel();
    if (!resultDiv) return;
    setBusy(true);
    setActiveFilter(fk);
    resultDiv.replaceChildren();
    const loading = document.createElement('p');
    loading.className = 'text-body-muted text-sm';
    loading.textContent = 'Loading…';
    resultDiv.appendChild(loading);

    try {
      const query = fk ? `?kind=${encodeURIComponent(fk)}` : '';
      const url = `/api/quotes${query}`;
      const response = await fetch(url);
      const data = await response.json();

      if (data.error) {
        resultDiv.replaceChildren();
        const err = document.createElement('p');
        err.className = 'text-red-500 text-sm';
        err.textContent = data.message || 'Error';
        resultDiv.appendChild(err);
        return;
      }

      const quote = data.quote;
      const meta = data.metadata;
      const kindLabel = quote.kind || 'stoic';
      const badgeClass =
        kindLabel === 'site'
          ? 'bg-emerald-500/15 text-emerald-700 dark:text-emerald-300'
          : kindLabel === 'philosophical'
            ? 'bg-violet-500/15 text-violet-700 dark:text-violet-300'
            : 'bg-slate-500/15 text-slate-700 dark:text-slate-300';

      const esc = (s: string) =>
        s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

      const linkBlock =
        quote.sourceUrl &&
        `<p class="mt-3"><a href="${esc(quote.sourceUrl)}" class="font-medium text-blue-500 hover:text-blue-600 underline underline-offset-2">Read the piece →</a></p>`;

      const kr = meta?.kindRequested;
      const poolSize = typeof meta?.selectionPoolSize === 'number' ? meta.selectionPoolSize : null;
      const fb = meta?.usedFallbackToFullPool === true;
      const serverSawKind = kr == null ? 'none (full collection)' : String(kr);
      const requested =
        fk === ''
          ? 'Client filter: none (any)'
          : `Client filter: ${esc(fk)} · Server kindRequested: ${esc(serverSawKind)}`;

      const mismatch =
        fk !== '' && (kr == null || String(kr) !== fk)
          ? `<p class="m-0 text-xs text-amber-700 dark:text-amber-400">Query did not line up: UI sent <code>${esc(fk)}</code> but API metadata has kindRequested=<code>${kr == null ? 'null' : esc(String(kr))}</code>.</p>`
          : '';

      resultDiv.innerHTML = `
        <div class="space-y-4">
          <div class="flex flex-wrap items-center gap-2">
            <span class="rounded-full px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wide ${badgeClass}">${esc(kindLabel)}</span>
            ${
              meta?.countsByKind
                ? `<span class="text-body-muted text-xs">Pool: ${meta.countsByKind.stoic ?? '—'} stoic · ${meta.countsByKind.philosophical ?? '—'} other · ${meta.countsByKind.site ?? '—'} site</span>`
                : ''
            }
          </div>
          <p class="text-body-muted m-0 font-mono text-xs"><code>${esc(url)}</code></p>
          <p class="text-body-muted m-0 text-xs">${requested}</p>
          ${poolSize != null ? `<p class="text-body-muted m-0 text-xs">Selection pool size for this draw: ${poolSize}${fb ? ' (fell back to full list — bucket empty in data)' : ''}</p>` : ''}
          ${fb ? `<p class="m-0 text-xs font-medium text-amber-700 dark:text-amber-400">Fallback: site/stoic/philosophy bucket had no quotes in data — using full pool.</p>` : ''}
          ${mismatch}
          <div class="rounded-sm border-l-4 border-blue-500 bg-[rgb(var(--color-bg-alt))] p-4">
            <p class="mb-2 text-lg italic leading-snug">"${esc(quote.text)}"</p>
            <p class="text-body-muted text-sm">— ${esc(quote.author)}${quote.work ? `, <em>${esc(quote.work)}</em>` : ''}${quote.book ? ` · ${esc(quote.book)}` : ''}</p>
            ${linkBlock || ''}
          </div>
          <dl class="grid grid-cols-2 gap-3 text-sm md:grid-cols-4">
            <div><dt class="font-medium text-[rgb(var(--color-text))]">Themes</dt><dd class="text-body-muted m-0">${esc((quote.themes || []).join(', ') || '—')}</dd></div>
            <div><dt class="font-medium text-[rgb(var(--color-text))]">Difficulty</dt><dd class="text-body-muted m-0">${esc(quote.difficulty)}</dd></div>
            <div><dt class="font-medium text-[rgb(var(--color-text))]">Length</dt><dd class="text-body-muted m-0">${esc(quote.length)}</dd></div>
            <div><dt class="font-medium text-[rgb(var(--color-text))]">Total in API</dt><dd class="text-body-muted m-0">${meta?.totalQuotes ?? '—'}</dd></div>
          </dl>
          ${
            quote.context
              ? `<p class="text-body-muted border-t border-[rgb(var(--color-border))]/30 pt-3 text-sm"><span class="font-medium text-[rgb(var(--color-text))]">Context: </span>${esc(quote.context)}</p>`
              : ''
          }
        </div>
      `;
    } catch (e) {
      resultDiv.replaceChildren();
      const err = document.createElement('p');
      err.className = 'text-red-500 text-sm';
      err.textContent = e instanceof Error ? e.message : 'Unknown error';
      resultDiv.appendChild(err);
    } finally {
      setBusy(false);
    }
  }

  function attachQuoteTester(): void {
    document.getElementById('testApiAny')?.addEventListener('click', () => fetchQuote(''));
    document.getElementById('testApiStoic')?.addEventListener('click', () => fetchQuote('stoic'));
    document
      .getElementById('testApiPhil')
      ?.addEventListener('click', () => fetchQuote('philosophical'));
    document.getElementById('testApiSite')?.addEventListener('click', () => fetchQuote('site'));
  }

  // Bundled Astro scripts can run before the layout slot is in the DOM — wait for it.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', attachQuoteTester);
  } else {
    attachQuoteTester();
  }
</script>
