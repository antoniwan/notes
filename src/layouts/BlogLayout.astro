---
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Comments from '../components/Comments.astro';
import RelatedPosts from '../components/related-posts/RelatedPosts.astro';
import Container from '../components/Container.astro';
import DefaultImage from '../components/DefaultImage.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SocialShare from '../components/SocialShare.astro';
import LanguageToggle from '../components/LanguageToggle.astro';
import PostTocModal from '../components/post-toc/PostTocModal.astro';
import { generateCanonicalUrl } from '../utils/seo';
import type { BlogLayoutProps } from '../types/layout';

interface Props extends BlogLayoutProps {}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  minutesRead,
  tags,
  category,
  categoryItems = [],
  path,
  imageAlt,
  author,
  keywords,
  tableOfContents,
  showComments = true,
  translationData,
  ...rest
} = Astro.props as Props;

// Generate canonical URL automatically
const canonical = path || generateCanonicalUrl(Astro.url.pathname);

// Use Astro's native post.id directly (no regex, no normalization)
const postId = rest.currentPost?.id || '';
const postSlug = postId; // Alias for backward compatibility in template
const primaryCategory = categoryItems[0] || null;
---

<BaseLayout
  title={title}
  description={description}
  pubDate={pubDate}
  updatedDate={updatedDate}
  heroImage={heroImage}
  minutesRead={minutesRead}
  tags={tags}
  category={category}
  path={canonical}
  imageAlt={imageAlt}
  author={author}
  keywords={keywords}
  type="article"
  structuredDataType="article"
  tableOfContents={tableOfContents}
  hasComments={showComments}
  featured={rest.featured}
  draft={rest.draft}
  postId={postId}
  {...rest}
>
  <Container>
    <div class="py-8 md:py-10 lg:py-12">
      {/* Breadcrumbs - Hidden on mobile, visible on desktop */}
      <div class="mb-6 hidden md:block">
        <Breadcrumbs
          items={[
            { label: 'Home', href: '/' },
            ...(primaryCategory
              ? [{ label: primaryCategory.name, href: `/category/${primaryCategory.id}/` }]
              : []),
            { label: title },
          ]}
          class="text-sm"
        />
      </div>

      {/* Hero Section - Full width on mobile, moves to sidebar on desktop */}
      <div class="mb-10 md:mb-12 lg:hidden">
        <PageHeader title={title} description={description} className="!mb-6" />
      </div>

      {/* Main Layout: Mobile-first, then 75/25 on desktop */}
      <div class="lg:grid lg:grid-cols-4 lg:gap-10 xl:gap-12">
        {/* Sidebar - Hidden on mobile, visible on desktop */}
        <aside class="hidden lg:col-span-1 lg:block">
          <div class="sticky top-6 max-h-[calc(100vh-2.5rem)] space-y-8 overflow-y-auto pr-2 pt-6">
            {/* Post Title & Description - Only shown in sidebar on desktop */}
            <div class="space-y-2">
              <h1 class="mb-4 text-2xl font-bold leading-tight text-[rgb(var(--color-text))]">
                {title}
              </h1>
              {
                description && (
                  <p class="text-body-muted m-0 text-base leading-relaxed">{description}</p>
                )
              }
            </div>

            {/* Reading Signals */}
            {
              minutesRead && (
                <div
                  class="reading-time-section space-y-2 leading-relaxed"
                  data-post-slug={postSlug}
                  data-original-reading-time={minutesRead}
                >
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                    Reading Signals
                  </h3>
                  <div class="flex items-center gap-2 text-base leading-relaxed text-[rgb(var(--color-text))]">
                    <span class="reading-time-icon text-[rgb(var(--color-accent))]">⏱️</span>
                    <span class="reading-time-value">{minutesRead}</span>
                  </div>
                </div>
              )
            }

            {/* Taxonomy */}
            {
              (categoryItems.length > 0 || (tags && tags.length > 0)) && (
                <div class="space-y-4 leading-relaxed">
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                    Taxonomy
                  </h3>

                  {categoryItems.length > 0 && (
                    <div class="space-y-2">
                      <p class="m-0 text-[11px] font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                        Categories
                      </p>
                      <div class="flex flex-wrap gap-1.5 text-xs leading-tight">
                        {categoryItems.map((item) => (
                          <a
                            href={`/category/${item.id}/`}
                            class="theme-transition rounded-full border border-[rgb(var(--color-border))] px-2 py-0.5 text-[rgb(var(--color-text))] hover:border-[rgb(var(--color-accent))] hover:text-[rgb(var(--color-accent))]"
                          >
                            {item.name}
                          </a>
                        ))}
                      </div>
                    </div>
                  )}

                  {tags && tags.length > 0 && (
                    <div class="space-y-2">
                      <p class="m-0 text-[11px] font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                        Tags
                      </p>
                      <div class="flex flex-wrap gap-1 text-sm">
                        {tags.map((tag) => (
                          <a
                            href={`/tag/${tag}/`}
                            class="text-[rgb(var(--color-accent))] transition-colors hover:text-[rgb(var(--color-accent))]/80 hover:underline"
                          >
                            #{tag}
                          </a>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              )
            }

            {/* Actions */}
            <div class="space-y-2">
              <h3
                class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]"
              >
                Actions
              </h3>
              <SocialShare
                title={title}
                description={description}
                url={canonical}
                variant="vertical"
              />
              {
                showComments && (
                  <a
                    href="#post-comments"
                    class="theme-transition flex w-full items-center gap-2 rounded-lg bg-[rgb(var(--color-bg-alt))] px-3 py-2 text-left text-sm font-medium text-[rgb(var(--color-accent))] hover:bg-[rgb(var(--color-bg-alt))]/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-primary))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg))]"
                  >
                    <span aria-hidden="true">💬</span>
                    <span>Comment on this post</span>
                  </a>
                )
              }
            </div>

            {/* Secondary Metadata */}
            {
              pubDate && (
                <div class="space-y-6 leading-relaxed">
                  {pubDate && (
                    <div class="space-y-2">
                      <h3 class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                        Publication
                      </h3>
                      <time
                        datetime={pubDate.toISOString()}
                        class="flex items-center gap-2 text-base leading-relaxed text-[rgb(var(--color-text))]"
                      >
                        <span class="text-[rgb(var(--color-accent))]">📅</span>
                        <FormattedDate date={pubDate} format="long" />
                      </time>
                      {updatedDate && updatedDate.getTime() !== pubDate?.getTime() && (
                        <time
                          datetime={updatedDate.toISOString()}
                          class="mt-1 flex items-center gap-2 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]"
                        >
                          <span class="text-[rgb(var(--color-accent))]">🔄</span>
                          <span>
                            Updated on <FormattedDate date={updatedDate} format="long" />
                          </span>
                        </time>
                      )}
                    </div>
                  )}
                </div>
              )
            }
          </div>
        </aside>

        {/* Main Content Area - Full width on mobile, 75% on desktop */}
        <main class="lg:col-span-3">
          {/* Hero Image - First thing in main content */}
          <div class="mb-8 md:mb-12">
            {
              heroImage ? (
                <img
                  src={heroImage}
                  alt={imageAlt || title}
                  class="h-[450px] w-full rounded-lg object-cover shadow-lg md:rounded-xl"
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  width="1200"
                  height="450"
                />
              ) : (
                <DefaultImage
                  alt={imageAlt || title}
                  className="w-full h-[450px] object-cover rounded-lg shadow-lg md:rounded-xl"
                  loading="eager"
                  priority={true}
                />
              )
            }
          </div>

          {/* Language Toggle */}
          {
            translationData?.hasTranslations && (
              <LanguageToggle
                translations={translationData.translations}
                currentLanguage={translationData.currentLanguage}
                currentPath={translationData.currentPath}
              />
            )
          }

          <div id="post-top" aria-hidden="true"></div>

          {/* Content */}
          <div
            class="post-prose prose prose-lg prose-headings:scroll-mt-24 prose-p:leading-relaxed prose-p:text-[rgb(var(--color-text))]"
            data-post-slug={postSlug}
          >
            <slot />
          </div>

          {/* Floating TOC (shown only when enough headings exist) */}
          <PostTocModal tableOfContents={tableOfContents} />

          {/* Mobile/Tablet metadata - collapsed by default */}
          <div class="mt-12 space-y-3 border-t border-[rgb(var(--color-border))] pt-8 lg:hidden">
            {
              minutesRead && (
                <details class="rounded-lg border border-[rgb(var(--color-border))] px-4 py-3">
                  <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                    Reading Signals
                  </summary>
                  <div
                    class="reading-time-section mt-3 space-y-2"
                    data-post-slug={postSlug}
                    data-original-reading-time={minutesRead}
                  >
                    <div class="flex items-center gap-2 text-base leading-relaxed text-[rgb(var(--color-text))]">
                      <span class="reading-time-icon text-[rgb(var(--color-text))]">⏱️</span>
                      <span class="reading-time-value">{minutesRead}</span>
                    </div>
                  </div>
                </details>
              )
            }

            {
              (categoryItems.length > 0 || (tags && tags.length > 0)) && (
                <details class="rounded-lg border border-[rgb(var(--color-border))] px-4 py-3">
                  <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                    Taxonomy
                  </summary>
                  <div class="mt-3 space-y-3">
                    {categoryItems.length > 0 && (
                      <div class="space-y-2">
                        <p class="m-0 text-[11px] font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                          Categories
                        </p>
                        <div class="flex flex-wrap gap-1.5 text-xs leading-tight">
                          {categoryItems.map((item) => (
                            <a
                              href={`/category/${item.id}/`}
                              class="theme-transition rounded-full border border-[rgb(var(--color-border))] px-2 py-0.5 text-[rgb(var(--color-text))] hover:border-[rgb(var(--color-accent))] hover:text-[rgb(var(--color-accent))]"
                            >
                              {item.name}
                            </a>
                          ))}
                        </div>
                      </div>
                    )}

                    {tags && tags.length > 0 && (
                      <div class="space-y-2">
                        <p class="m-0 text-[11px] font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                          Tags
                        </p>
                        <div class="flex flex-wrap gap-1 text-sm">
                          {tags.map((tag) => (
                            <a
                              href={`/tag/${tag}/`}
                              class="text-[rgb(var(--color-accent))] transition-colors hover:text-[rgb(var(--color-accent))]/80 hover:underline"
                            >
                              #{tag}
                            </a>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </details>
              )
            }

            <details class="rounded-lg border border-[rgb(var(--color-border))] px-4 py-3">
              <summary
                class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]"
              >
                Actions
              </summary>
              <div class="mt-3 space-y-3">
                <SocialShare
                  title={title}
                  description={description}
                  url={canonical}
                  variant="horizontal"
                />
                {
                  showComments && (
                    <a
                      href="#post-comments"
                      class="theme-transition inline-flex w-full items-center justify-center gap-2 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-alt))] px-4 py-2 text-sm font-medium text-[rgb(var(--color-accent))] hover:bg-[rgb(var(--color-bg-alt))]/80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-primary))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg))] sm:justify-start"
                    >
                      <span aria-hidden="true">💬</span>
                      <span>Comment on this post</span>
                    </a>
                  )
                }
              </div>
            </details>

            {
              pubDate && (
                <details class="rounded-lg border border-[rgb(var(--color-border))] px-4 py-3">
                  <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                    Secondary Metadata
                  </summary>
                  <div class="mt-3 space-y-4">
                    {pubDate && (
                      <div class="space-y-2">
                        <h3 class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]">
                          Publication
                        </h3>
                        <time
                          datetime={pubDate.toISOString()}
                          class="flex items-center gap-2 text-base leading-relaxed text-[rgb(var(--color-text))]"
                        >
                          <span class="text-[rgb(var(--color-accent))]">📅</span>
                          <FormattedDate date={pubDate} format="long" />
                        </time>
                        {updatedDate && updatedDate.getTime() !== pubDate?.getTime() && (
                          <time
                            datetime={updatedDate.toISOString()}
                            class="mt-1 flex items-center gap-2 text-sm leading-relaxed text-[rgb(var(--color-text-muted))]"
                          >
                            <span class="text-[rgb(var(--color-accent))]">🔄</span>
                            <span>
                              Updated on <FormattedDate date={updatedDate} format="long" />
                            </span>
                          </time>
                        )}
                      </div>
                    )}
                  </div>
                </details>
              )
            }
          </div>

          {/* Comments */}
          {showComments && <Comments />}

          <RelatedPosts currentPost={rest.currentPost} allPosts={rest.allPosts} />
        </main>
      </div>
    </div>
  </Container>
</BaseLayout>

<script>
  import { formatRelativeReadTime } from '../utils/relativeReadTime.client';
  import '../components/post-toc/postToc.client';

  // Read slug from DOM (set on main content wrapper) so this script can stay a module
  const postSlug = document.querySelector('[data-post-slug]')?.getAttribute('data-post-slug');

  // ReadStateService is initialized by ReadStateServiceInit component in BaseLayout
  // Get the singleton instance
  const readStateService = window.ReadStateService?.getInstance();

  function updateReadStatus() {
    if (!postSlug || !readStateService) return; // Exit early if slug or service not available
    const readData = readStateService.getReadData(postSlug);

    // Reading time sections (both desktop and mobile)
    const readingTimeSections = document.querySelectorAll(
      `.reading-time-section[data-post-slug="${postSlug}"]`,
    );

    if (readData) {
      const relativeTime = formatRelativeReadTime(readData.readAt);

      // Update reading time sections to show relative time
      readingTimeSections.forEach((section) => {
        const timeValueElement = section.querySelector('.reading-time-value');
        const iconElement = section.querySelector('.reading-time-icon');
        const headingElement = section.querySelector('h3');

        if (timeValueElement) {
          timeValueElement.textContent = relativeTime;
          timeValueElement.setAttribute('datetime', readData.readAt);
        }

        // Change the icon to indicate read status
        if (iconElement) {
          iconElement.textContent = '✓';
          iconElement.classList.remove(
            'text-[rgb(var(--color-accent))]',
            'text-[rgb(var(--color-text))]',
          );
          iconElement.classList.add('text-[rgb(34,197,94)]');
        }

        // Hide the "Reading Time" heading when already read for cleaner flow
        if (headingElement) {
          headingElement.classList.add('sr-only');
        }
      });
    } else {
      // Restore original reading time for unread posts
      readingTimeSections.forEach((section) => {
        const originalReadingTime = section.getAttribute('data-original-reading-time');
        const timeValueElement = section.querySelector('.reading-time-value');
        const iconElement = section.querySelector('.reading-time-icon');
        const headingElement = section.querySelector('h3');

        if (timeValueElement && originalReadingTime) {
          timeValueElement.textContent = originalReadingTime;
          timeValueElement.removeAttribute('datetime');
        }

        // Restore the icon
        if (iconElement) {
          iconElement.textContent = '⏱️';
          iconElement.classList.remove('text-[rgb(34,197,94)]');
          // Restore original color based on context (desktop has accent, mobile has text)
          const isMobile = section.closest('.lg\\:hidden');
          if (isMobile) {
            iconElement.classList.add('text-[rgb(var(--color-text))]');
          } else {
            iconElement.classList.add('text-[rgb(var(--color-accent))]');
          }
        }

        // Restore heading for unread posts
        if (headingElement) {
          headingElement.classList.remove('sr-only');
        }
      });
    }
  }

  // Subscribe to read state changes (only if service is available)
  let unsubscribe = null;
  if (readStateService) {
    unsubscribe = readStateService.subscribeToAll(() => {
      updateReadStatus();
    });

    // Initial update
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateReadStatus);
    } else {
      updateReadStatus();
    }
  }

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    if (unsubscribe) {
      unsubscribe();
    }
  });
</script>
