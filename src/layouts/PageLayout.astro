---
import BaseLayout from './BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import Container from '../components/Container.astro';
import type { BaseLayoutProps } from '../types/layout';

interface Props extends BaseLayoutProps {
  /** Replaces default `prose prose-lg max-w-none` wrapper when you need a custom page layout */
  contentClass?: string;
}

const {
  title,
  description,
  path,
  imageAlt,
  author,
  keywords,
  structuredDataType,
  structuredDataIdentifier,
  posts,
  showTitle = true,
  contentClass = 'prose prose-lg max-w-none',
  ...rest
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  imageAlt={imageAlt}
  author={author}
  keywords={keywords}
  structuredDataType={structuredDataType}
  structuredDataIdentifier={structuredDataIdentifier}
  posts={posts}
  {...rest}
>
  <Container>
    <PageHeader title={title} description={description} showTitle={showTitle} />

    {/* Page Content */}
    <div class={contentClass}>
      <slot />
    </div>
  </Container>
</BaseLayout>
