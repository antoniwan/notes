---
import type { LetterboxdFeedItem } from '../../utils/letterboxdRss';

interface Props {
  items: LetterboxdFeedItem[];
  profileUrl?: string;
  maxItems?: number;
}

const { items, profileUrl, maxItems = 8 } = Astro.props;
const slice = items.slice(0, maxItems);
---

{
  slice.length > 0 && (
    <section
      class="mt-10 border-t border-[rgb(var(--color-border))]/30 pt-10"
      aria-labelledby="letterboxd-recent-heading"
    >
      <h2
        id="letterboxd-recent-heading"
        class="mb-1 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
      >
        Recent on Letterboxd
      </h2>
      <p class="text-body-muted mb-4 text-sm">
        Public activity from{' '}
        {profileUrl ? (
          <a
            href={profileUrl}
            class="text-[rgb(var(--color-primary))] underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            my profile
          </a>
        ) : (
          'my profile'
        )}
        . Links open Letterboxd.
      </p>
      <ul class="space-y-3 text-left">
        {slice.map((item) => (
          <li>
            <a
              href={item.link}
              class="group block rounded-lg border border-transparent px-1 py-1 transition-colors hover:border-[rgb(var(--color-border))]/40 hover:bg-[rgb(var(--color-bg-alt))]/50"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="block font-medium text-[rgb(var(--color-text))] group-hover:text-[rgb(var(--color-primary))]">
                {item.title}
              </span>
              {item.publishedAt && (
                <span class="text-body-muted block text-xs">{item.publishedAt}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
