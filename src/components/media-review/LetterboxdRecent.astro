---
import type { LetterboxdFeedItem } from '../../utils/letterboxdRss';

interface Props {
  items: LetterboxdFeedItem[];
  profileUrl?: string;
  maxItems?: number;
  /** Root section classes; default fits below an in-panel trailer. */
  rootClass?: string;
}

const {
  items,
  profileUrl,
  maxItems = 8,
  rootClass = 'mt-10 border-t border-[rgb(var(--color-border))]/30 pt-10',
} = Astro.props;
const slice = items.slice(0, maxItems);

/** Unicode star row for Letterboxd 0.5–5.0 ratings (RSS has no genre; this is what we can show instead). */
function formatRatingStars(n: number): string {
  const clamped = Math.min(5, Math.max(0, n));
  const full = Math.floor(clamped);
  const half = clamped - full >= 0.45 && clamped - full < 1 ? 1 : 0;
  const empty = 5 - full - half;
  return `${'★'.repeat(full)}${half ? '½' : ''}${'☆'.repeat(empty)}`;
}

function displayHeadline(item: LetterboxdFeedItem): string {
  if (item.filmTitle) {
    return item.filmYear != null ? `${item.filmTitle} (${item.filmYear})` : item.filmTitle;
  }
  return item.title;
}
---

{
  slice.length > 0 && (
    <section class:list={[rootClass]} aria-labelledby="letterboxd-recent-heading">
      <h2
        id="letterboxd-recent-heading"
        class="mb-1 text-lg font-semibold text-[rgb(var(--color-text))] md:text-xl"
      >
        Recent on Letterboxd
      </h2>
      <p class="text-body-muted mb-6 text-sm">
        Public activity from{' '}
        {profileUrl ? (
          <a
            href={profileUrl}
            class="text-[rgb(var(--color-primary))] underline-offset-2 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            my profile
          </a>
        ) : (
          'my profile'
        )}
        . Links open Letterboxd.
      </p>
      <ul class="m-0 grid list-none grid-cols-1 gap-3 p-0 sm:grid-cols-2 sm:gap-4" role="list">
        {slice.map((item) => (
          <li class="min-w-0">
            <a
              href={item.link}
              class="group flex h-full min-h-[5rem] gap-3 rounded-lg border border-[rgb(var(--color-border))]/25 bg-[rgb(var(--color-bg))]/80 p-3 shadow-sm transition-colors duration-200 hover:border-[rgb(var(--color-primary))]/35 hover:bg-[rgb(var(--color-bg-alt))]/60 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[rgb(var(--color-primary))] sm:gap-4 sm:p-4"
              target="_blank"
              rel="noopener noreferrer"
            >
              {item.posterUrl ? (
                <div class="relative w-14 shrink-0 overflow-hidden rounded-md border border-[rgb(var(--color-border))]/30 sm:w-16">
                  <img
                    src={item.posterUrl}
                    alt={`Poster: ${item.filmTitle ?? item.title}`}
                    class="aspect-[2/3] h-full w-full object-cover"
                    loading="lazy"
                    decoding="async"
                    width="64"
                    height="96"
                  />
                </div>
              ) : (
                <div
                  class="flex w-14 shrink-0 items-center justify-center rounded-md border border-dashed border-[rgb(var(--color-border))]/40 bg-[rgb(var(--color-bg-alt))]/50 text-lg opacity-60 sm:w-16"
                  aria-hidden="true"
                >
                  🎬
                </div>
              )}
              <div class="flex min-w-0 flex-1 flex-col justify-between gap-2">
                <span class="line-clamp-2 text-sm font-semibold leading-snug text-[rgb(var(--color-text))] group-hover:text-[rgb(var(--color-primary))]">
                  {displayHeadline(item)}
                </span>
                <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs">
                  {item.memberRating != null && Number.isFinite(item.memberRating) && (
                    <span
                      class="text-[rgb(var(--color-accent))]"
                      aria-label={`Rated ${item.memberRating} out of 5`}
                    >
                      {formatRatingStars(item.memberRating)}
                    </span>
                  )}
                  {item.rewatch === true && (
                    <span class="rounded border border-[rgb(var(--color-border))]/40 px-1.5 py-0.5 text-[0.65rem] font-medium uppercase tracking-wide text-[rgb(var(--color-text-muted))]">
                      Rewatch
                    </span>
                  )}
                  {item.memberLike === true && (
                    <span class="text-[rgb(var(--color-text-muted))]" title="Liked">
                      ♥
                    </span>
                  )}
                </div>
                {(item.watchedDate || item.publishedAt) && (
                  <span class="text-body-muted text-[0.7rem] tabular-nums opacity-90">
                    {item.watchedDate ?? item.publishedAt}
                  </span>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
