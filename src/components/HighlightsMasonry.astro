---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';
import { categories } from '../data/categories';
import { buildHighlightsLayout, type LayoutSlot } from '../utils/highlightsLayout';
import { calculateReadingTimeFromMarkdown } from '../utils/readingTime';

interface Props {
  posts: CollectionEntry<'blog'>[];
  postsByCategory?: Record<string, CollectionEntry<'blog'>[]>;
}

const { posts, postsByCategory = {} } = Astro.props;

// Categories that have highlights (from "All" list or from any category list)
const categorySet = new Set<string>(Object.keys(postsByCategory));
for (const post of posts) {
  (post.data.category || []).forEach((id: string) => categorySet.add(id));
}
const availableCategories = categories.filter((cat) => categorySet.has(cat.id));

const PRIMARY_CATEGORY_LIMIT = 5;

// Desktop layout: only specific row types (2 equal, 2 emphasis, 3 equal, 3 emphasis 1st/2nd/3rd)
const allSlots = buildHighlightsLayout(posts);

function serializePost(p: CollectionEntry<'blog'>) {
  return {
    id: p.id,
    title: p.data.title,
    description: p.data.description || '',
    pubDate: p.data.pubDate instanceof Date ? p.data.pubDate.toISOString() : String(p.data.pubDate),
    heroImage: p.data.heroImage || '',
    imageAlt: p.data.imageAlt || p.data.title,
    readingTime: calculateReadingTimeFromMarkdown(p.body || ''),
  };
}

// Payload for client: per-category layout + serialized posts (so we can render up to 12 per category)
const payload: Record<string, { layout: { rowIndex: number; colStart: number; span: number }[]; posts: ReturnType<typeof serializePost>[] }> = {};
for (const [catId, list] of Object.entries(postsByCategory)) {
  const layout = buildHighlightsLayout(list);
  payload[catId] = {
    layout: layout.map((s) => ({ rowIndex: s.rowIndex, colStart: s.colStart, span: s.span })),
    posts: list.map(serializePost),
  };
}
---

<section class="highlights-section" aria-labelledby="highlights-heading">
  <header class="highlights-header">
    <div class="highlights-heading">
      <h2 id="highlights-heading" class="highlights-title">Highlights</h2>
      <p class="highlights-subtitle">
        Hand-picked writings from recent seasons — a curated starting point, not a full index.
      </p>
    </div>

    {availableCategories.length > 0 && (
      <div class="highlights-filters" aria-label="Filter highlights by category" role="toolbar">
        <button
          type="button"
          class="filter-chip is-active"
          data-filter="all"
          aria-label="Show all highlights"
          aria-pressed="true"
        >
          All
        </button>
        {availableCategories.map((category, index) => (
          <button
            type="button"
            class="filter-chip"
            class:list={{ 'is-extra': index >= PRIMARY_CATEGORY_LIMIT }}
            data-filter={category.id}
            data-category-name={category.name}
            aria-label={`Show posts in ${category.name}`}
            aria-pressed="false"
          >
            {category.icon && <span aria-hidden="true">{category.icon}</span>}
            <span>{category.name}</span>
          </button>
        ))}
        {availableCategories.length > PRIMARY_CATEGORY_LIMIT && (
          <button
            type="button"
            class="filter-chip filter-chip--more"
            data-toggle-more
            aria-label="Show more categories"
            aria-expanded="false"
          >
            More
          </button>
        )}
      </div>
    )}
  </header>

  <p class="highlights-status" data-highlights-status>
    Showing {posts.length} highlights (All categories)
  </p>

  <div class="highlights-masonry" data-highlights-grid>
    {allSlots.map((slot) => (
      <div
        class="masonry-item"
        class:list={[`span-${slot.span}`]}
        style={`grid-row: ${slot.rowIndex + 1}; grid-column: ${slot.colStart} / span ${slot.span};`}
        data-filter-set="all"
      >
        <PostCard post={slot.post} featured={slot.post.data.featured || slot.post.data.highlight} showFeaturedIndicator={false} />
      </div>
    ))}
  </div>
</section>

<script define:vars={{ payload }}>
  function formatDate(iso) {
    try {
      const d = new Date(iso);
      return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch {
      return '';
    }
  }

  function buildCardHTML(post) {
    const url = `/p/${post.id}/`;
    const alt = post.imageAlt || post.title;
    const imgHtml = post.heroImage
      ? `<img src="${escapeHtml(post.heroImage)}" alt="${escapeHtml(alt)}" loading="lazy" />`
      : `<div class="h-full w-full bg-[rgb(var(--color-bg-alt))]" aria-hidden="true"></div>`;

    // Structure closely mirrors PostCard so "All" vs filtered layouts match
    return `
<article class="interactive-card group relative overflow-hidden rounded-lg" role="article" data-post-slug="${escapeHtml(
      post.id,
    )}">
  <div class="read-indicator" data-post-slug="${escapeHtml(post.id)}">
    <span class="read-dot"></span>
  </div>
  <div class="image-container relative overflow-hidden rounded-t-lg">
    ${imgHtml}
  </div>
  <div class="relative p-3 sm:p-4 md:p-5">
    <div class="space-y-3">
      <header class="space-y-2">
        <div class="text-body-muted flex items-center gap-1.5 text-xs leading-relaxed">
          <span>${formatDate(post.pubDate)}</span>
          ${
            post.readingTime
              ? `<span class="reading-time-display" data-post-slug="${escapeHtml(
                  post.id,
                )}" data-original-reading-time="${escapeHtml(
                  post.readingTime,
                )}"><span aria-hidden="true">•</span><span>${escapeHtml(
                  post.readingTime,
                )}</span></span>`
              : ''
          }
        </div>
        <h2 class="postcard-title text-base leading-tight text-[rgb(var(--color-text))] sm:text-lg md:text-xl" id="postcard-title-${escapeHtml(
          post.id,
        )}">
          <a href="${escapeHtml(url)}" class="block" style="font-weight: 700 !important;">
            ${escapeHtml(post.title)}
          </a>
        </h2>
      </header>
      ${
        post.description
          ? `<p class="postcard-description text-body-muted mt-2 line-clamp-2 text-sm leading-relaxed sm:text-base md:line-clamp-2">${escapeHtml(
              post.description,
            )}</p>`
          : ''
      }
    </div>
  </div>
</article>`;
  }

  function escapeHtml(s) {
    if (!s) return '';
    const div = document.createElement('div');
    div.textContent = s;
    return div.innerHTML;
  }

  const grid = document.querySelector('[data-highlights-grid]');
  const filterButtons = Array.from(document.querySelectorAll('.highlights-filters .filter-chip[data-filter]'));
  const moreToggle = document.querySelector('[data-toggle-more]');
  const statusEl = document.querySelector('[data-highlights-status]');

  let savedAllHTML = '';

  function applyFilter(filter) {
    filterButtons.forEach((btn) => {
      const isActive = btn.dataset.filter === filter;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });

    const categoryName = filter === 'all' ? 'All categories' : (document.querySelector(`.filter-chip[data-filter="${filter}"]`)?.dataset?.categoryName || filter);

    if (filter === 'all') {
      if (savedAllHTML) {
        grid.innerHTML = savedAllHTML;
      }
      if (statusEl) statusEl.textContent = `Showing ${grid.querySelectorAll('.masonry-item').length} highlights (${categoryName})`;
      return;
    }

    const data = payload && payload[filter];
    if (!data || !data.posts.length) {
      if (statusEl) statusEl.textContent = `No highlights in ${categoryName}`;
      grid.innerHTML = `<div class="highlights-empty" style="grid-column: 1 / -1; padding: 3rem; text-align: center; color: rgb(var(--color-text-muted));">No highlights in this category yet.</div>`;
      return;
    }

    const { layout, posts: categoryPosts } = data;
    let html = '';
    layout.forEach((slot, i) => {
      const post = categoryPosts[i];
      if (!post) return;
      const card = buildCardHTML(post);
      html += `<div class="masonry-item span-${slot.span}" data-filter-set="${escapeHtml(filter)}" style="grid-row: ${slot.rowIndex + 1}; grid-column: ${slot.colStart} / span ${slot.span};">${card}</div>`;
    });
    grid.innerHTML = html;
    if (statusEl) statusEl.textContent = `Showing ${categoryPosts.length} highlights (${categoryName})`;
  }

  if (grid && filterButtons.length) {
    savedAllHTML = grid.innerHTML;

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        applyFilter(btn.dataset.filter || 'all');
      });
    });
  }

  if (moreToggle) {
    const filtersContainer = document.querySelector('.highlights-filters');
    moreToggle.addEventListener('click', () => {
      if (!filtersContainer) return;
      const expanded = filtersContainer.classList.toggle('filters-expanded');
      moreToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      moreToggle.textContent = expanded ? 'Less' : 'More';
    });
  }
</script>

<style>
  .highlights-section {
    margin-top: 3.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .highlights-section {
      margin-top: 4.5rem;
      margin-bottom: 4rem;
    }
  }

  .highlights-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .highlights-header {
      flex-direction: row;
      align-items: flex-end;
      margin-bottom: 2.25rem;
    }
  }

  .highlights-heading {
    max-width: 28rem;
  }

  .highlights-title {
    font-size: 1.75rem;
    line-height: 1.3;
    font-weight: 700;
    margin: 0;
  }

  @media (min-width: 768px) {
    .highlights-title {
      font-size: 2rem;
    }
  }

  .highlights-subtitle {
    margin-top: 0.4rem;
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(var(--color-text-muted));
  }

  .highlights-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: flex-start;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-border));
    background: rgb(var(--color-bg));
    color: rgb(var(--color-text-muted));
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    line-height: 1.2;
    cursor: pointer;
    transition:
      background-color 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.12s ease;
  }

  .filter-chip:hover {
    border-color: rgb(var(--color-primary) / 0.6);
    color: rgb(var(--color-text));
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.12);
    transform: translateY(-1px);
  }

  .filter-chip.is-active {
    background: rgb(var(--color-primary) / 0.1);
    border-color: rgb(var(--color-primary));
    color: rgb(var(--color-text));
    box-shadow: 0 0 0 1px rgb(var(--color-primary) / 0.5);
  }

  .filter-chip:focus-visible {
    outline: 2px solid rgb(var(--color-accent));
    outline-offset: 2px;
  }

  .filter-chip--more {
    background: transparent;
    border-style: dashed;
    font-weight: 500;
  }

  .filter-chip.is-extra {
    display: none;
  }

  .highlights-filters.filters-expanded .filter-chip.is-extra {
    display: inline-flex;
  }

  .highlights-status {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    color: rgb(var(--color-text-muted));
  }

  /* Desktop: 12-column grid, only allowed row patterns. Mobile: single column. */
  .highlights-masonry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .highlights-masonry {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 1.25rem 1.5rem;
      grid-auto-rows: auto;
    }
  }

  @media (min-width: 1024px) {
    .highlights-masonry {
      gap: 1.5rem 1.75rem;
    }
  }

  .masonry-item {
    min-width: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* Taller, uniform image height in highlights so all cards feel consistent (desktop only) */
  @media (min-width: 768px) {
    .highlights-masonry article.interactive-card .image-container {
      height: 14rem;
    }
  }

  /* Reset grid placement on mobile so items stack */
  @media (max-width: 767px) {
    .masonry-item {
      grid-column: 1 !important;
      grid-row: auto !important;
    }
  }

  .group:hover {
    box-shadow: 0 4px 12px -2px rgb(0 0 0 / 0.15);
    border-color: rgb(var(--color-primary) / 0.3);
  }
</style>
