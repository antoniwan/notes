---
import type { CollectionEntry } from 'astro:content';
import PostCard from './PostCard.astro';
import { categories } from '../data/categories';
import { buildHighlightsLayout, type LayoutSlot } from '../utils/highlightsLayout';

interface Props {
  posts: CollectionEntry<'blog'>[];
  postsByCategory?: Record<string, CollectionEntry<'blog'>[]>;
}

const { posts, postsByCategory = {} } = Astro.props;

// Categories that have highlights (from "All" list or from any category list)
const categorySet = new Set<string>(Object.keys(postsByCategory));
for (const post of posts) {
  (post.data.category || []).forEach((id: string) => categorySet.add(id));
}
const availableCategories = categories.filter((cat) => categorySet.has(cat.id));

const PRIMARY_CATEGORY_LIMIT = 5;

// Desktop layout: only specific row types (2 equal, 2 emphasis, 3 equal, 3 emphasis 1st/2nd/3rd)
const allSlots = buildHighlightsLayout(posts);

// Counts per view for status text (no HTML injection: every view is server-rendered with PostCard)
const viewCounts: Record<string, number> = { all: posts.length };
for (const [catId, list] of Object.entries(postsByCategory)) {
  viewCounts[catId] = list.length;
}
// Pre-build category slots for server render (same layout as "All", but per category)
const categorySlots: Record<string, LayoutSlot[]> = {};
for (const [catId, list] of Object.entries(postsByCategory)) {
  categorySlots[catId] = buildHighlightsLayout(list);
}
---

<section class="highlights-section" aria-labelledby="highlights-heading">
  <header class="highlights-header">
    <div class="highlights-heading">
      <h2 id="highlights-heading" class="highlights-title">Highlights</h2>
      <p class="highlights-subtitle">
        Hand-picked writings from recent seasons: a curated starting point, not a full index.
      </p>
    </div>

    {
      availableCategories.length > 0 && (
        <div class="highlights-filters" aria-label="Filter highlights by category" role="toolbar">
          <button
            type="button"
            class="filter-chip is-active"
            data-filter="all"
            aria-label="Show all highlights"
            aria-pressed="true"
          >
            All
          </button>
          {availableCategories.map((category, index) => (
            <button
              type="button"
              class="filter-chip"
              class:list={{ 'is-extra': index >= PRIMARY_CATEGORY_LIMIT }}
              data-filter={category.id}
              data-category-name={category.name}
              aria-label={`Show posts in ${category.name}`}
              aria-pressed="false"
            >
              {category.icon && <span aria-hidden="true">{category.icon}</span>}
              <span>{category.name}</span>
            </button>
          ))}
          {availableCategories.length > PRIMARY_CATEGORY_LIMIT && (
            <button
              type="button"
              class="filter-chip filter-chip--more"
              data-toggle-more
              aria-label="Show more categories"
              aria-expanded="false"
            >
              More
            </button>
          )}
        </div>
      )
    }
  </header>

  <p class="highlights-status" data-highlights-status>
    Showing {posts.length} highlights (All categories)
  </p>

  <div class="highlights-container" data-highlights-container data-active-view="all">
    <!-- All: same UI as filtered views (all use PostCard) -->
    <div class="highlights-masonry highlights-view" data-view="all" aria-hidden="false">
      {
        allSlots.map((slot) => (
          <div
            class="masonry-item"
            class:list={[`span-${slot.span}`]}
            style={`grid-row: ${slot.rowIndex + 1}; grid-column: ${slot.colStart} / span ${slot.span};`}
          >
            <PostCard
              post={slot.post}
              featured={slot.post.data.featured || slot.post.data.highlight}
              showFeaturedIndicator={false}
            />
          </div>
        ))
      }
    </div>
    <!-- One grid per category, same structure so styling is identical -->
    {
      Object.entries(categorySlots).map(([catId, slots]) => (
        <div class="highlights-masonry highlights-view" data-view={catId} aria-hidden="true" hidden>
          {slots.map((slot) => (
            <div
              class="masonry-item"
              class:list={[`span-${slot.span}`]}
              style={`grid-row: ${slot.rowIndex + 1}; grid-column: ${slot.colStart} / span ${slot.span};`}
            >
              <PostCard
                post={slot.post}
                featured={slot.post.data.featured || slot.post.data.highlight}
                showFeaturedIndicator={false}
              />
            </div>
          ))}
        </div>
      ))
    }
  </div>
</section>

<script is:inline define:vars={{ viewCounts }}>
  const container = document.querySelector('[data-highlights-container]');
  const filterButtons = Array.from(
    document.querySelectorAll('.highlights-filters .filter-chip[data-filter]'),
  );
  const moreToggle = document.querySelector('[data-toggle-more]');
  const statusEl = document.querySelector('[data-highlights-status]');

  function applyFilter(filter) {
    filterButtons.forEach((btn) => {
      const isActive = btn.dataset.filter === filter;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });

    if (container) container.setAttribute('data-active-view', filter);

    const categoryName =
      filter === 'all'
        ? 'All categories'
        : document.querySelector(`.filter-chip[data-filter="${filter}"]`)?.dataset?.categoryName ||
          filter;
    const count = viewCounts && viewCounts[filter] != null ? viewCounts[filter] : 0;
    if (statusEl) {
      statusEl.textContent =
        count === 0
          ? `No highlights in ${categoryName}`
          : `Showing ${count} highlight${count === 1 ? '' : 's'} (${categoryName})`;
    }

    // aria-hidden for a11y
    container?.querySelectorAll('.highlights-view').forEach((view) => {
      const viewId = view.getAttribute('data-view');
      view.setAttribute('aria-hidden', viewId !== filter ? 'true' : 'false');
      if (viewId !== filter) view.hidden = true;
      else view.hidden = false;
    });
  }

  if (container && filterButtons.length) {
    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        applyFilter(btn.dataset.filter || 'all');
      });
    });
  }

  if (moreToggle) {
    const filtersContainer = document.querySelector('.highlights-filters');
    moreToggle.addEventListener('click', () => {
      if (!filtersContainer) return;
      const expanded = filtersContainer.classList.toggle('filters-expanded');
      moreToggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      moreToggle.textContent = expanded ? 'Less' : 'More';
    });
  }
</script>

<style>
  .highlights-section {
    margin-top: 3.5rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .highlights-section {
      margin-top: 4.5rem;
      margin-bottom: 4rem;
    }
  }

  .highlights-header {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }

  .highlights-heading {
    max-width: 28rem;
  }

  .highlights-title {
    font-size: 1.75rem;
    line-height: 1.3;
    font-weight: 700;
    margin: 0;
  }

  @media (min-width: 768px) {
    .highlights-title {
      font-size: 2rem;
    }
  }

  .highlights-subtitle {
    margin-top: 0.4rem;
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(var(--color-text-muted));
  }

  .highlights-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: flex-start;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    border: 1px solid rgb(var(--color-border));
    background: rgb(var(--color-bg));
    color: rgb(var(--color-text-muted));
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    line-height: 1.2;
    cursor: pointer;
    transition:
      background-color 0.18s ease,
      color 0.18s ease,
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.12s ease;
  }

  .filter-chip:hover {
    border-color: rgb(var(--color-primary) / 0.6);
    color: rgb(var(--color-text));
    box-shadow: 0 2px 6px rgb(0 0 0 / 0.12);
    transform: translateY(-1px);
  }

  .filter-chip.is-active {
    background: rgb(var(--color-primary) / 0.1);
    border-color: rgb(var(--color-primary));
    color: rgb(var(--color-text));
    box-shadow: 0 0 0 1px rgb(var(--color-primary) / 0.5);
  }

  .filter-chip:focus-visible {
    outline: 2px solid rgb(var(--color-accent));
    outline-offset: 2px;
  }

  .filter-chip--more {
    background: transparent;
    border-style: dashed;
    font-weight: 500;
  }

  .filter-chip.is-extra {
    display: none;
  }

  .highlights-filters.filters-expanded .filter-chip.is-extra {
    display: inline-flex;
  }

  .highlights-status {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    color: rgb(var(--color-text-muted));
  }

  /* Only the active view is visible; all views use the same grid + PostCard so UI is identical */
  .highlights-view {
    display: grid;
  }
  .highlights-view[hidden] {
    display: none !important;
  }

  /* Desktop: 12-column grid, only allowed row patterns. Mobile: single column. */
  .highlights-masonry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .highlights-masonry {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 1.25rem 1.5rem;
      grid-auto-rows: auto;
    }
  }

  @media (min-width: 1024px) {
    .highlights-masonry {
      gap: 1.5rem 1.75rem;
    }
  }

  .masonry-item {
    min-width: 0;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  /* Same height per row: grid rows stretch, cards fill cell and use flex so content area grows */
  @media (min-width: 768px) {
    .highlights-masonry .masonry-item {
      display: flex;
    }
    .highlights-masonry .masonry-item article.interactive-card {
      display: flex;
      flex-direction: column;
      flex: 1;
      min-height: 0;
    }
    .highlights-masonry article.interactive-card > .relative {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 0;
    }
  }

  /* Reset grid placement on mobile so items stack */
  @media (max-width: 767px) {
    .masonry-item {
      grid-column: 1 !important;
      grid-row: auto !important;
    }
  }

  .highlights-masonry .group:hover {
    box-shadow: 0 4px 12px -2px rgb(0 0 0 / 0.15);
    border-color: rgb(var(--color-primary) / 0.3);
  }
</style>
