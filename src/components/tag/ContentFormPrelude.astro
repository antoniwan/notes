---
import type { ContentFormPreludeItem } from '../../utils/tag/contentFormTags';

interface Props {
  items: ContentFormPreludeItem[];
  connectors: string[];
}

const { items, connectors } = Astro.props;
---

<section
  class="mb-8 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-alt))]/20 px-4 py-3"
>
  <p class="text-body-large leading-relaxed text-[rgb(var(--color-text))]">
    I have written
    {
      items.map((item, index) => (
        <>
          <span>{connectors[index] ?? ', '}</span>
          <a
            href={item.href}
            class="font-medium text-[rgb(var(--color-accent))] underline decoration-[rgb(var(--color-accent))]/40 underline-offset-4 hover:text-[rgb(var(--color-accent-hover))]"
          >
            {item.label}
          </a>
        </>
      ))
    }
    .
  </p>
</section>
