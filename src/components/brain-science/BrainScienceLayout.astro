---
import Container from '../Container.astro';
import BrainScienceNav from './BrainScienceNav.astro';
import { getBrainSciencePage } from '../../data/brainScience';

interface Props {
  currentPage: string; // Path of current page
  title: string;
  description: string;
  emoji?: string;
  showNavLinks?: boolean;
}

const { currentPage, title, description, emoji, showNavLinks = true } = Astro.props;

const pageInfo = getBrainSciencePage(currentPage);
const displayEmoji = emoji || pageInfo?.emoji || '🧠';
---

<Container class="pt-6 md:pt-8">
  <Container maxWidth="container" padding="none">
    <BrainScienceNav currentPage={currentPage} showNavLinks={showNavLinks} />

    <div class="py-4 md:py-6 lg:py-8">
      {/* Header */}
      <div class="mb-6 md:mb-8 lg:mb-10">
        <h1
          class="text-display mb-3 text-[rgb(var(--color-text))] md:mb-4 lg:mb-5"
          transition:name="page-title"
        >
          {displayEmoji}
          <span class="highlight-primary">{title}</span>
        </h1>
        <p
          class="text-body-large text-body-muted max-w-4xl leading-relaxed"
          transition:name="page-description"
        >
          {description}
        </p>
      </div>

      <div class="brain-science-content">
        <slot />
      </div>
    </div>
  </Container>
</Container>
