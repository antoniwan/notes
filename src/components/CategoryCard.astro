---
import type { Category } from '../data/categories';

interface Props {
  category: Category;
  postCount: number;
  featured?: boolean;
  compact?: boolean;
}

const { category, postCount, featured = false, compact = false } = Astro.props;
---

<a
  href={`/category/${category.id}/`}
  class="interactive-card theme-transition group relative block overflow-hidden rounded-xl border border-[rgb(var(--color-border))]/20 bg-[rgb(var(--color-bg))] hover:border-[rgb(var(--color-accent))]/25 focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-bg))]"
  class:list={{
    'category-card-featured': featured,
    'category-card-compact': compact,
  }}
>
  <div class:list={[{ 'p-4 md:p-6': compact, 'p-6 md:p-8': !compact }]}>
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0">
        <div
          class="theme-transition flex h-12 w-12 items-center justify-center rounded-xl bg-[rgb(var(--color-accent))]/10 text-2xl md:h-14 md:w-14 md:text-3xl"
          aria-hidden="true"
        >
          {category.icon}
        </div>
      </div>

      <div class="min-w-0 flex-1">
        <h3
          class="mb-2 mt-0 text-xl font-semibold leading-tight text-[rgb(var(--color-text))] md:text-2xl"
        >
          {category.name}
        </h3>

        {
          !compact && (
            <p class="text-body-muted mb-4 mt-0 line-clamp-2 text-base leading-relaxed md:text-lg">
              {category.description}
            </p>
          )
        }

        <div class="flex items-center justify-between gap-2">
          <span class="text-body-muted text-sm font-medium md:text-base">
            {postCount}
            {postCount === 1 ? 'writing' : 'writings'}
          </span>
          <span class="text-[rgb(var(--color-accent))]" aria-hidden="true">→</span>
        </div>
      </div>
    </div>
  </div>
</a>

<style>
  .category-card-featured {
    border-color: rgb(var(--color-accent) / 0.18);
    box-shadow: 0 2px 10px -3px rgb(0 0 0 / 0.08);
  }

  :global(.dark) .category-card-featured {
    box-shadow: 0 2px 14px -2px rgb(0 0 0 / 0.35);
  }

  h3 {
    margin-top: 0 !important;
  }

  p {
    margin-top: 0 !important;
  }

  @media (max-width: 768px) {
    .flex-shrink-0 .h-12 {
      height: 2.5rem;
      width: 2.5rem;
    }

    .flex-shrink-0 .text-2xl {
      font-size: 1.25rem;
      line-height: 1.75rem;
    }
  }
</style>
