---
import { mainNavigation } from '../data/navigation';
import { getSortedCategories } from '../utils/categoryUtils';
import {
  dropdownActiveClasses,
  isMainNavItemActive,
  isNavDropdownItemActive,
  normalizePathname,
} from '../utils/navActive';

// Get sorted categories for the mobile navigation
const sortedCategories = await getSortedCategories();
// @ts-ignore Astro is injected in .astro frontmatter runtime.
const currentPathname = Astro.url.pathname;

const mobilePrimaryNavigation = [
  { href: '/', label: 'Home' },
  { href: '/everything', label: 'Posts' },
  { href: '/about', label: 'About' },
];

const isPrimaryMobileNavActive = (href: string, pathname: string) => {
  const p = normalizePathname(pathname);
  const h = normalizePathname(href);
  if (h === '/everything') {
    return p === '/everything' || p.startsWith('/p/');
  }
  if (h === '/brain-science') {
    return p === '/brain-science' || p.startsWith('/brain-science/');
  }
  return p === h;
};
---

<!-- Hamburger Button -->
<button
  id="mobile-menu-button"
  type="button"
  aria-label="Open menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
  class="theme-transition inline-flex items-center justify-center rounded-lg p-2 text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-bg-alt))] focus:outline-none focus:ring-2 focus:ring-[rgb(var(--color-accent))] xl:hidden"
>
  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M4 6h16M4 12h16M4 18h16"></path>
  </svg>
</button>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 flex hidden h-screen w-full transform flex-col bg-[rgb(var(--color-bg))] transition-transform duration-300 ease-in-out xl:hidden"
  tabindex="-1"
  aria-modal="true"
  role="dialog"
  aria-label="Mobile navigation menu"
>
  <!-- Menu Header -->
  <div class="flex items-center justify-between border-b border-[rgb(var(--color-border))] p-6">
    <span class="text-2xl font-bold text-[rgb(var(--color-text))]">Menu</span>
    <button
      type="button"
      aria-label="Close menu"
      class="theme-transition rounded-lg p-2 text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-bg-alt))] focus:outline-none focus:ring-2 focus:ring-[rgb(var(--color-accent))]"
      id="close-mobile-menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Navigation Content -->
  <div class="flex-1 overflow-y-auto">
    <!-- Primary Navigation -->
    <nav class="space-y-6 p-6" aria-label="Primary navigation">
      <div class="space-y-2">
        <p
          class="px-2 text-xs font-semibold uppercase tracking-wide text-[rgb(var(--color-text-muted))]"
        >
          Core
        </p>
        {
          mobilePrimaryNavigation.map((item) => {
            const isActive = isPrimaryMobileNavActive(item.href, currentPathname);
            return (
              <a
                href={item.href}
                class:list={[
                  'theme-transition flex items-center justify-between rounded-xl px-4 py-3 text-lg hover:bg-[rgb(var(--color-bg-alt))]',
                  isActive
                    ? 'bg-[rgb(var(--color-accent))]/10 font-semibold text-[rgb(var(--color-accent))]'
                    : 'font-semibold text-[rgb(var(--color-text))]',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                <span>{item.label}</span>
              </a>
            );
          })
        }
        <button
          id="mobile-search-nav-action"
          type="button"
          class="theme-transition flex w-full items-center justify-between rounded-xl px-4 py-3 text-left text-lg font-semibold text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-bg-alt))]"
          aria-label="Open search"
        >
          <span>Search</span>
          <span aria-hidden="true">/</span>
        </button>
      </div>

      <div class="border-t border-[rgb(var(--color-border))]"></div>

      {
        mainNavigation.map((item) => {
          const isActive = isMainNavItemActive(item.href, currentPathname);

          return (
            <div class="space-y-2">
              <a
                href={item.href}
                class:list={[
                  'theme-transition flex items-center justify-between rounded-xl px-4 py-4 text-xl font-semibold hover:bg-[rgb(var(--color-bg-alt))]',
                  isActive
                    ? 'bg-[rgb(var(--color-accent))]/10 text-[rgb(var(--color-accent))]'
                    : 'text-[rgb(var(--color-text))]',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                <span>{item.label}</span>
                {item.dropdown && (
                  <svg
                    class="h-5 w-5 text-[rgb(var(--color-text-muted))]"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                )}
              </a>
              {item.dropdown && item.href === '/category/' && (
                <div class="ml-4 space-y-1">
                  {sortedCategories.map((category) => {
                    const catHref = `/category/${category.id}/`;
                    const subActive = isNavDropdownItemActive(catHref, currentPathname);
                    return (
                      <a
                        href={catHref}
                        class:list={[
                          'theme-transition flex items-center justify-between rounded-lg px-4 py-3 text-lg hover:bg-[rgb(var(--color-bg-alt))]',
                          subActive ? dropdownActiveClasses : 'text-[rgb(var(--color-text-muted))]',
                        ]}
                        aria-current={subActive ? 'page' : undefined}
                      >
                        <div class="flex items-center gap-3">
                          {category.icon && (
                            <span class="text-xl" aria-hidden="true">
                              {category.icon}
                            </span>
                          )}
                          <span>{category.name}</span>
                        </div>
                        <span class="rounded-full bg-[rgb(var(--color-bg-alt))] px-2 py-1 text-sm text-[rgb(var(--color-text-muted))]">
                          {category.postCount}
                        </span>
                      </a>
                    );
                  })}
                </div>
              )}
              {item.dropdown && item.href !== '/category/' && (
                <div class="ml-4 space-y-1">
                  {(item.dropdown.items ?? []).map((dropdownItem) => {
                    const subActive = isNavDropdownItemActive(dropdownItem.href, currentPathname);
                    return (
                      <a
                        href={dropdownItem.href}
                        class:list={[
                          'theme-transition flex items-center gap-3 rounded-lg px-4 py-3 text-lg hover:bg-[rgb(var(--color-bg-alt))]',
                          subActive ? dropdownActiveClasses : 'text-[rgb(var(--color-text-muted))]',
                        ]}
                        aria-current={subActive ? 'page' : undefined}
                      >
                        {dropdownItem.icon && (
                          <span class="text-xl" aria-hidden="true">
                            {dropdownItem.icon}
                          </span>
                        )}
                        <span>{dropdownItem.label}</span>
                      </a>
                    );
                  })}
                </div>
              )}
            </div>
          );
        })
      }
    </nav>

    <!-- Quick Actions -->
    <div class="border-t border-[rgb(var(--color-border))] px-6 py-4">
      <div class="space-y-3">
        <button
          id="mobile-share-button"
          class="theme-transition flex w-full items-center gap-3 rounded-xl bg-[rgb(var(--color-bg-alt))] px-4 py-4 text-lg font-medium text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-bg-alt))]/80"
          aria-label="Share this page"
        >
          <span class="text-xl" aria-hidden="true">📤</span>
          <span>Share This Page</span>
        </button>
      </div>
    </div>

    <!-- Social Links -->
    <div class="border-t border-[rgb(var(--color-border))] px-6 py-6">
      <h3
        class="mb-4 text-sm font-semibold uppercase tracking-wider text-[rgb(var(--color-text-muted))]"
      >
        Connect
      </h3>
      <div class="flex gap-4">
        <a
          href="https://bsky.app/profile/antoniwan.online"
          target="_blank"
          rel="noopener noreferrer"
          class="theme-transition flex flex-1 items-center justify-center gap-2 rounded-lg bg-[rgb(var(--color-bg-alt))] px-4 py-3 hover:bg-[rgb(var(--color-bg-alt))]/80"
          aria-label="Follow on BlueSky"
        >
          <span class="text-xl">🌀</span>
          <span class="text-sm font-medium">BlueSky</span>
        </a>
        <a
          href="https://github.com/antoniwan/strongvault"
          target="_blank"
          rel="noopener noreferrer"
          class="theme-transition flex flex-1 items-center justify-center gap-2 rounded-lg bg-[rgb(var(--color-bg-alt))] px-4 py-3 hover:bg-[rgb(var(--color-bg-alt))]/80"
          aria-label="View on GitHub"
        >
          <span class="text-xl">🐙</span>
          <span class="text-sm font-medium">GitHub</span>
        </a>
        <a
          href="https://www.youtube.com/@Antoniwan777"
          target="_blank"
          rel="noopener noreferrer"
          class="theme-transition flex flex-1 items-center justify-center gap-2 rounded-lg bg-[rgb(var(--color-bg-alt))] px-4 py-3 hover:bg-[rgb(var(--color-bg-alt))]/80"
          aria-label="Watch on YouTube"
        >
          <span class="text-xl">📺</span>
          <span class="text-sm font-medium">YouTube</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  let menuButton: HTMLElement | null = null;
  let menu: HTMLElement | null = null;
  let closeButton: HTMLElement | null = null;
  let searchActionButton: HTMLElement | null = null;
  let isInitialized = false;
  let hasMenuHistoryEntry = false;
  let isProgrammaticBack = false;

  function isMenuOpen() {
    return !!menu && !menu.classList.contains('hidden');
  }

  function getFocusableElements() {
    if (!menu) return [];
    return Array.from(
      menu.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    ).filter((el) => !el.hasAttribute('hidden'));
  }

  function recordDismissReason(reason: string) {
    if (menu) {
      menu.dataset.dismissReason = reason;
    }
  }

  function openMenu() {
    if (!menu || !menuButton || isMenuOpen()) return;
    menu.classList.remove('hidden');
    menuButton.setAttribute('aria-expanded', 'true');
    document.body.classList.add('overflow-hidden');
    recordDismissReason('open');

    if (!hasMenuHistoryEntry) {
      history.pushState({ mobileMenu: 'open' }, '', window.location.href);
      hasMenuHistoryEntry = true;
    }

    const [firstFocusable] = getFocusableElements();
    if (firstFocusable) {
      firstFocusable.focus();
    }
  }

  function closeMenu(reason = 'close-button', shouldRestoreFocus = true, syncHistory = true) {
    if (!menu || !menuButton || !isMenuOpen()) return;
    menu.classList.add('hidden');
    menuButton.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('overflow-hidden');
    recordDismissReason(reason);

    if (syncHistory && hasMenuHistoryEntry && reason !== 'back-action') {
      isProgrammaticBack = true;
      history.back();
    }

    if (shouldRestoreFocus) {
      menuButton.focus();
    }
  }

  function handleOverlayClick(e: Event) {
    if (e.target === menu) {
      closeMenu('overlay-tap');
    }
  }

  function handlePopState() {
    if (isProgrammaticBack) {
      isProgrammaticBack = false;
      hasMenuHistoryEntry = false;
      return;
    }

    if (isMenuOpen()) {
      hasMenuHistoryEntry = false;
      closeMenu('back-action', true, false);
    }
  }

  function showToast(message: string) {
    const toast = document.createElement('div');
    toast.className =
      'fixed bottom-20 left-1/2 transform -translate-x-1/2 bg-[rgb(var(--color-bg))] border border-[rgb(var(--color-border))] text-[rgb(var(--color-text))] px-4 py-2 rounded-lg shadow-lg z-50 theme-transition';
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
  }

  function trapFocus(event: KeyboardEvent) {
    const focusables = getFocusableElements();
    if (!focusables.length) return;

    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    const active = document.activeElement as HTMLElement | null;

    if (event.shiftKey && active === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && active === last) {
      event.preventDefault();
      first.focus();
    }
  }

  function handleKeydown(e: KeyboardEvent) {
    if (!isMenuOpen()) return;
    if (e.key === 'Escape') {
      closeMenu('escape-key');
      return;
    }
    if (e.key === 'Tab') {
      trapFocus(e);
    }
  }

  function handleSearchAction() {
    closeMenu('link-selection');
    document.dispatchEvent(new CustomEvent('mobile-nav:open-search'));
  }

  function handleCloseButtonClick() {
    closeMenu('close-button');
  }

  function handleNavLinkClick() {
    closeMenu('link-selection', false);
  }

  async function handleShareClick() {
    closeMenu('link-selection');

    if (navigator.share) {
      try {
        await navigator.share({
          title: document.title,
          text: document.querySelector('meta[name="description"]')?.getAttribute('content') || '',
          url: window.location.href,
        });
      } catch {
        // User canceled share.
      }
      return;
    }

    const pageUrl = window.location.href;
    try {
      await navigator.clipboard.writeText(pageUrl);
      showToast('Link copied to clipboard!');
    } catch {
      const textArea = document.createElement('textarea');
      textArea.value = pageUrl;
      document.body.appendChild(textArea);
      textArea.select();
      document.body.removeChild(textArea);
      showToast('Link ready — press Ctrl+C to copy.');
    }
  }

  function initializeMobileNav() {
    if (isInitialized) return;

    menuButton = document.getElementById('mobile-menu-button');
    menu = document.getElementById('mobile-menu');
    closeButton = document.getElementById('close-mobile-menu');
    searchActionButton = document.getElementById('mobile-search-nav-action');

    if (!menuButton || !menu || !closeButton) return;

    menuButton.addEventListener('click', openMenu);
    closeButton.addEventListener('click', handleCloseButtonClick);
    menu.addEventListener('click', handleOverlayClick);
    document.addEventListener('keydown', handleKeydown);
    window.addEventListener('popstate', handlePopState);

    const navLinks = menu.querySelectorAll('a');
    navLinks.forEach((link) => {
      link.addEventListener('click', handleNavLinkClick);
    });

    if (searchActionButton) {
      searchActionButton.addEventListener('click', handleSearchAction);
    }

    const mobileShareButton = document.getElementById('mobile-share-button');
    if (mobileShareButton) {
      mobileShareButton.addEventListener('click', handleShareClick);
    }

    isInitialized = true;
  }

  function cleanup() {
    if (!isInitialized) return;

    menuButton?.removeEventListener('click', openMenu);
    closeButton?.removeEventListener('click', handleCloseButtonClick);
    menu?.removeEventListener('click', handleOverlayClick);
    document.removeEventListener('keydown', handleKeydown);
    window.removeEventListener('popstate', handlePopState);
    const navLinks = menu?.querySelectorAll('a');
    navLinks?.forEach((link) => link.removeEventListener('click', handleNavLinkClick));
    searchActionButton?.removeEventListener('click', handleSearchAction);
    isInitialized = false;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeMobileNav);
  } else {
    initializeMobileNav();
  }

  window.addEventListener('beforeunload', cleanup);
</script>

<style>
  @media (min-width: 1280px) {
    #mobile-menu-button {
      display: none;
    }
    #mobile-menu {
      display: none !important;
    }
  }
</style>
