---
import { fetchThreadsOEmbed, stripThreadsEmbedScript } from '../utils/threadsEmbed';

interface Props {
  url: string;
  maxwidth?: number;
}

const { url, maxwidth = 540 } = Astro.props;

let markup: string | null = null;

try {
  const oembed = await fetchThreadsOEmbed(url, maxwidth);
  markup = stripThreadsEmbedScript(oembed.html);
} catch (error) {
  console.error('[ThreadsEmbed]', error);
}
---

<figure
  class="threads-embed not-prose theme-transition my-8 w-full"
  aria-label="Embedded Threads post"
>
  <div
    class="threads-embed__shell overflow-hidden rounded-lg border border-[rgb(var(--color-border))] border-l-4 border-l-[rgb(var(--color-accent))] bg-[rgb(var(--color-bg-alt))]/50 px-3 py-3 shadow-xs md:rounded-xl md:px-4 md:py-4"
  >
    {
      markup ? (
        <div class="threads-embed__frame threads-embed__frame--loading" set:html={markup} />
      ) : (
        <p class="text-body-muted m-0 text-center text-sm">
          <a
            href={url}
            rel="noopener noreferrer"
            target="_blank"
            class="link font-medium"
          >
            Open this post on Threads
          </a>
        </p>
      )
    }
  </div>
</figure>

{markup && <script is:inline async src="https://www.threads.com/embed.js"></script>}

<script>
  function watchThreadsEmbeds() {
    document.querySelectorAll('.threads-embed__frame--loading').forEach((frame) => {
      const ready = () => frame.classList.remove('threads-embed__frame--loading');

      if (frame.querySelector('iframe')) {
        ready();
        return;
      }

      const observer = new MutationObserver(() => {
        if (frame.querySelector('iframe')) {
          ready();
          observer.disconnect();
        }
      });
      observer.observe(frame, { childList: true, subtree: true });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', watchThreadsEmbeds);
  } else {
    watchThreadsEmbeds();
  }

  document.addEventListener('astro:page-load', watchThreadsEmbeds);
</script>

<style>
  .threads-embed__frame {
    margin: 0 auto;
    width: 100%;
    max-width: 658px;
  }

  .threads-embed__frame--loading {
    min-height: 6rem;
    position: relative;
  }

  .threads-embed__frame--loading::before {
    content: '';
    position: absolute;
    inset: 0.5rem 0.25rem;
    border-radius: 0.5rem;
    background: linear-gradient(
      110deg,
      rgb(var(--color-bg)) 8%,
      rgb(var(--color-bg-alt)) 18%,
      rgb(var(--color-bg)) 33%
    );
    background-size: 200% 100%;
    animation: threads-embed-shimmer 1.4s ease-in-out infinite;
  }

  @keyframes threads-embed-shimmer {
    to {
      background-position-x: -200%;
    }
  }

  .threads-embed__frame :global(blockquote.text-post-media) {
    margin: 0 auto !important;
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    border: none !important;
    border-radius: 0.375rem !important;
    box-shadow: none !important;
  }

  .threads-embed__frame :global(blockquote.text-post-media a) {
    background: transparent !important;
    font-family: inherit !important;
  }

  .threads-embed__frame :global(blockquote.text-post-media iframe) {
    display: block;
    width: 100% !important;
    margin: 0 !important;
    border: none !important;
    border-radius: 0.375rem !important;
    background: rgb(var(--color-bg)) !important;
  }

  .threads-embed__frame--loading :global(blockquote.text-post-media) {
    opacity: 0;
    pointer-events: none;
  }

  .threads-embed__frame:not(.threads-embed__frame--loading) :global(blockquote.text-post-media) {
    opacity: 1;
    transition: opacity 0.2s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .threads-embed__frame--loading::before {
      animation: none;
      background: rgb(var(--color-bg-alt));
    }

    .threads-embed__frame:not(.threads-embed__frame--loading) :global(blockquote.text-post-media) {
      transition: none;
    }
  }
</style>
