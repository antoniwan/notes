---
import {
  fetchThreadsOEmbed,
  normalizeThreadsPostUrl,
  prepareThreadsEmbedMarkup,
} from '../utils/threadsEmbed';

interface Props {
  url: string;
  maxwidth?: number;
}

const { url, maxwidth = 540 } = Astro.props;
const canonicalUrl = normalizeThreadsPostUrl(url);

let markup: string | null = null;

try {
  const oembed = await fetchThreadsOEmbed(canonicalUrl, maxwidth);
  markup = prepareThreadsEmbedMarkup(oembed.html);
} catch (error) {
  console.error('[ThreadsEmbed]', error);
}
---

<figure
  class="threads-embed not-prose theme-transition my-8 w-full"
  aria-label="Embedded Threads post"
>
  <div
    class="threads-embed__shell overflow-hidden rounded-lg border border-[rgb(var(--color-border))] border-l-4 border-l-[rgb(var(--color-accent))] bg-[rgb(var(--color-bg-alt))]/50 px-3 py-3 shadow-xs md:rounded-xl md:px-4 md:py-4"
  >
    {
      markup ? (
        <div class="threads-embed__frame" set:html={markup} />
      ) : (
        <p class="text-body-muted m-0 text-center text-sm">
          <a
            href={canonicalUrl}
            rel="noopener noreferrer"
            target="_blank"
            class="link font-medium"
          >
            Open this post on Threads
          </a>
        </p>
      )
    }
  </div>
</figure>

{
  markup && (
    <script>
      import { initThreadsEmbeds } from '../utils/threadsEmbed.client';
      import { THEME_CHANGE_EVENT } from '../utils/themeEvents';

      initThreadsEmbeds();

      document.addEventListener('astro:page-load', () => {
        initThreadsEmbeds();
      });

      document.addEventListener(THEME_CHANGE_EVENT, () => {
        initThreadsEmbeds();
      });
    </script>
  )
}

<style>
  .threads-embed__frame {
    margin: 0 auto;
    width: 100%;
    max-width: 658px;
    min-height: 4.5rem;
  }

  .threads-embed__frame :global(blockquote.text-post-media) {
    margin: 0 auto !important;
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    border: none !important;
    border-radius: 0.375rem !important;
    box-shadow: none !important;
  }

  .threads-embed__frame :global(blockquote.text-post-media a) {
    background: transparent !important;
    font-family: inherit !important;
  }

  .threads-embed__frame :global(iframe) {
    display: block;
    width: 100% !important;
    margin: 0 auto !important;
    border: none !important;
    border-radius: 0.375rem !important;
    background: rgb(var(--color-bg)) !important;
  }

  /* Meta hides the blockquote once the iframe is inserted; keep layout stable. */
  .threads-embed__frame :global(blockquote.text-post-media-registered) {
    display: none !important;
  }

  .threads-embed__frame--failed :global(blockquote.text-post-media) {
    opacity: 1 !important;
    pointer-events: auto !important;
  }
</style>
