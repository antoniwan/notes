---
import type { TocItem } from '../../types/layout';

interface Props {
  tableOfContents?: TocItem[];
}

const { tableOfContents = [] } = Astro.props;
const hasToc = tableOfContents.length >= 2;
---

{
  hasToc && (
    <div class="post-toc-container" data-post-toc>
      <button
        type="button"
        class="post-toc-trigger"
        aria-expanded="false"
        aria-controls="post-toc-modal"
        data-post-toc-trigger
      >
        Contents
      </button>

      <div
        id="post-toc-modal"
        class="post-toc-modal hidden"
        role="dialog"
        aria-modal="false"
        aria-label="Table of contents"
        data-post-toc-modal
      >
        <div class="post-toc-card">
          <div class="post-toc-header">
            <h2 class="post-toc-title">On this page</h2>
            <button
              type="button"
              class="post-toc-close"
              aria-label="Close contents"
              data-post-toc-close
            >
              ×
            </button>
          </div>

          <nav aria-label="Table of contents" class="post-toc-nav">
            <ol class="post-toc-list">
              {tableOfContents.map((item) => (
                <li
                  class="post-toc-item"
                  data-level={item.level}
                  style={`--toc-indent: ${Math.max(0, item.level - 2)};`}
                >
                  <a href={`#${item.slug}`} data-post-toc-link={item.slug}>
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </div>
      </div>
    </div>
  )
}

<style>
  .post-toc-container {
    position: fixed;
    left: 1rem;
    right: auto;
    bottom: 1rem;
    z-index: 40;
  }

  .post-toc-trigger {
    border: 1px solid rgb(var(--color-border));
    background: color-mix(in srgb, rgb(var(--color-bg)) 85%, rgb(var(--color-accent)) 15%);
    color: rgb(var(--color-text));
    border-radius: 999px;
    padding: 0.6rem 0.95rem;
    font-size: 0.9rem;
    font-weight: 600;
    box-shadow: 0 10px 30px rgb(0 0 0 / 0.16);
    backdrop-filter: blur(6px);
    transition:
      transform 140ms ease,
      box-shadow 140ms ease;
  }

  .post-toc-trigger:hover {
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgb(0 0 0 / 0.18);
  }

  .post-toc-modal {
    position: fixed;
    inset: auto 0 0 0;
    padding: 0.75rem;
    background: rgb(0 0 0 / 0.42);
  }

  .post-toc-modal.hidden {
    display: none;
  }

  .post-toc-card {
    margin-left: auto;
    width: min(100%, 420px);
    max-height: min(70vh, 520px);
    border: 1px solid rgb(var(--color-border));
    border-radius: 1rem;
    background: rgb(var(--color-bg));
    box-shadow: 0 18px 45px rgb(0 0 0 / 0.26);
    overflow: hidden;
  }

  .post-toc-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid rgb(var(--color-border));
    padding: 0.85rem 1rem;
  }

  .post-toc-title {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  .post-toc-close {
    border: 0;
    background: transparent;
    color: rgb(var(--color-text-muted));
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
  }

  .post-toc-nav {
    overflow: auto;
    max-height: min(62vh, 460px);
    padding: 0.5rem 0;
  }

  .post-toc-list {
    list-style: none;
    margin: 0;
    padding: 0 0.75rem;
  }

  .post-toc-item {
    margin: 0;
  }

  .post-toc-item a {
    display: block;
    padding: 0.5rem 0.65rem;
    margin-left: calc(var(--toc-indent) * 0.85rem);
    border-radius: 0.5rem;
    color: rgb(var(--color-text));
    text-decoration: none;
    font-size: 0.92rem;
    line-height: 1.45;
    transition:
      background-color 120ms ease,
      color 120ms ease;
  }

  .post-toc-item a:hover,
  .post-toc-item a:focus-visible {
    outline: none;
    color: rgb(var(--color-accent));
    background: color-mix(in srgb, rgb(var(--color-accent)) 14%, transparent);
  }

  .post-toc-item a[data-active='true'] {
    color: rgb(var(--color-accent));
    background: color-mix(in srgb, rgb(var(--color-accent)) 17%, transparent);
    font-weight: 600;
  }

  @media (min-width: 1024px) {
    .post-toc-container {
      left: auto;
      right: 2rem;
      bottom: 6.5rem;
    }

    .post-toc-modal {
      inset: auto 2rem 10rem auto;
      width: 360px;
      background: transparent;
      padding: 0;
    }

    .post-toc-card {
      width: 100%;
      max-height: min(72vh, 560px);
    }
  }
</style>
